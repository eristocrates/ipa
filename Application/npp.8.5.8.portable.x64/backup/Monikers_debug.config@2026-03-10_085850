					<QUERY nodeId="4756"
					       name="AgingReport"
					       sql="select sum(tranamt) as SUM30,'1' as COLUMN1  from Billing.ACCTTRAN where blkey in (select blkey from Billing.custbl where paidstat='N' and stg4prckey &gt; 1 and  @StartDate - bldate &gt;= 30 and @StartDate  - bldate &lt; 60) UNION select sum(tranamt),'2' as COLUMN1 from Billing.ACCTTRAN where blkey in (select blkey from Billing.custbl where paidstat='N' and stg4prckey &gt; 1 and  @StartDate - bldate &gt;=60 and @StartDate  - bldate &lt; 90) UNION select sum(tranamt),'3' as COLUMN1 from Billing.ACCTTRAN where blkey in (select blkey from Billing.custbl where paidstat='N' and stg4prckey &gt; 1 and  @StartDate - bldate &gt;=90 and @StartDate  - bldate &lt; 120) UNION select sum(tranamt),'4' as COLUMN1 from Billing.ACCTTRAN where blkey in (select blkey from Billing.custbl where paidstat='N' and stg4prckey &gt; 1 and  @StartDate - bldate &gt;=120) ORDER BY COLUMN1"
					       type="item"
					       accid="0"
