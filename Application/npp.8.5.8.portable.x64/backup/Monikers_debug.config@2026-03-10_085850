				<QUERIES nodeId="5737">
					<QUERY nodeId="5738"
					       name="WOOpenReport"
					       sql="Select a.ACTCODE,a.ACTDESC, count(*) as CountColumn from WorkManagement.history h, WorkManagement.actdefn a where h.actkey = a.actkey and a.COMPFLAG = 'N' group by a.actkey,a.actcode,a.actdesc order by 1"
					       type="item"
					       accid="0"/>
					<QUERY nodeId="5739"
					       name="WOACTIVITYReport"
					       sql="SELECT C.COMPCODE, H.INITDTTM, H.SCHEDDTTM, H.STARTDTTM, H.WONO FROM WorkManagement.actdefn A, AssetManagement.comptype C, WorkManagement.history H WHERE H.ACTKEY = A.ACTKEY AND H.COMPTYPE = C.COMPTYPE AND ((H.COMPFLAG='N') AND (A.ACTCODE=@ActCode)) ORDER BY 2, 3, 4, 5"
					       type="item"
					       accid="0"/>
					<QUERY nodeId="5740"
					       name="WOAssetReport"
					       sql="SELECT A.ACTCODE, H.INITDTTM, H.SCHEDDTTM, H.STARTDTTM, H.WONO FROM WorkManagement.actdefn A, AssetManagement.comptype C, WorkManagement.history H WHERE H.ACTKEY = A.ACTKEY AND H.COMPTYPE = C.COMPTYPE AND ((H.COMPFLAG='N') AND (C.COMPCODE=@CompCode)) ORDER BY 2, 3, 4, 5"
					       type="item"
					       accid="0"/>
					<QUERY nodeId="5741"
					       name="WOOpenAreaReport"
					       sql="SELECT A.ACTCODE, C.COMPCODE, H.INITDTTM, H.SCHEDDTTM, H.STARTDTTM, H.WONO FROM WorkManagement.actdefn A, AssetManagement.comptype C, AssetManagement.COMP COMP, WorkManagement.history H WHERE H.ACTKEY = A.ACTKEY AND H.COMPTYPE = C.COMPTYPE AND H.COMPKEY = COMP.COMPKEY AND ((H.COMPFLAG='N') AND (COMP.AREA= @AREA)) ORDER BY 3, 4, 5, 6 "
					       type="item"
					       accid="0"/>
					<QUERY nodeId="5742"
					       name="WOCostReport"
					       sql="SELECT ISNULL(sum(LABRCOST),0) + ISNULL(sum(EQCOST),0) + ISNULL(sum(VEHCOST),0) + ISNULL(sum(PRTCOST),0) +  ISNULL(sum(EXTRACOST),0) as SUMCOLUMN,RCOSTSUM.ACTCODE FROM imsv7.RCOSTSUM RCOSTSUM WHERE (RCOSTSUM.COMPDTTM &gt;=@StartDate And RCOSTSUM.COMPDTTM &lt;= @EndDate) GROUP BY RCOSTSUM.ACTCODE ORDER BY 2"
					       type="item"
					       accid="0"/>
					<QUERY nodeId="5743"
					       name="WOCostActivityReport"
					       sql="SELECT R.WONO, C.COMPCODE as CODE, R.COMPDTTM, ISNULL(sum(LABRCOST),0) + ISNULL(sum(EQCOST),0) + ISNULL(sum(VEHCOST),0) + ISNULL(sum(PRTCOST),0) +  ISNULL(sum(EXTRACOST),0)  as SUMCOLUMN, R.LABRCOST, R.EQCOST, R.VEHCOST, R.PRTCOST, R.EXTRACOST FROM AssetManagement.comptype C, WorkManagement.history H, imsv7.RCOSTSUM R WHERE R.HISTKEY = H.HISTKEY AND H.COMPTYPE = C.COMPTYPE AND ((R.COMPDTTM&gt;=@StartDate)) group by actcode,r.wono, c.compcode,r.compdttm,labrcost,eqcost,vehcost,prtcost,extracost ORDER BY 2,3"
					       accid="0"/>
					<QUERY nodeId="5744"
					       name="WOCostAssetReport"
					       sql="SELECT R.WONO, ACTCODE as CODE, R.COMPDTTM, ISNULL(sum(LABRCOST),0) + ISNULL(sum(EQCOST),0) + ISNULL(sum(VEHCOST),0) + ISNULL(sum(PRTCOST),0) +  ISNULL(sum(EXTRACOST),0) as SUMCOLUMN, R.LABRCOST, R.EQCOST, R.VEHCOST, R.PRTCOST, R.EXTRACOST FROM AssetManagement.comptype C, WorkManagement.history H, imsv7.RCOSTSUM R WHERE R.HISTKEY = H.HISTKEY AND H.COMPTYPE = C.COMPTYPE AND ((R.COMPDTTM&gt;=@StartDate)) group by actcode,r.wono, c.compcode,r.compdttm,labrcost,eqcost,vehcost,prtcost,extracost ORDER BY 2,3"
					       accid="0"/>
					<QUERY nodeId="5745"
					       name="WOOpenReportReport"
					       sql="select convert(char(10), INITDTTM, 111) as WODate,count(*) as WOCount FROM WorkManagement.history where compflag = 'N' and INITDTTM &gt;= @StartDate and INITDTTM &lt;= @EndDate group by convert(char(10), INITDTTM, 111)"
					       type="item"
					       accid="0"/>
					<QUERY nodeId="5746"
					       name="WOFailuresReport"
					       sql="SELECT c.COMPCODE, Count(*) as FAILURECOUNT FROM AssetManagement.comptype c, WorkManagement.history h WHERE (h.FAILFLAG='Y') AND (h.COMPDTTM &gt;= @STARTDATE And h.COMPDTTM &lt;= @EndDate) AND (h.COMPTYPE=c.comptype) GROUP BY c.COMPCODE ORDER BY 1"
					       type="item"
