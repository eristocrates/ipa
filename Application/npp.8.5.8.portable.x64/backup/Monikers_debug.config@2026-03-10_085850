			           name="ServiceRequestCollection"
			           file="CustomerService"
			           path="CRM"/>
			<COMPONENT nodeId="4333"
			           name="CustomerCall"
			           file="CustomerService"
			           path="CRM">
				<QUERIES nodeId="4334">
					<QUERY nodeId="4335"
					       name="SROpenReport"
					       sql="select max(c.prob) as SRCode,max(d.probdesc) as SRDesc, count(*) as CountColumn from CRM.custprob c,CRM.probdefn d where probdttm &gt;= @StartDate and probdttm &lt;= @EndDate and c.prob = d.probcode and c.resflag = 'N' group by prob"
					       type="item"
					       accid="0"/>
					<QUERY nodeId="4336"
					       name="SROpenTimeFrameDayReport"
					       sql="select c.prob as SRCode,d.probdesc as SRDesc,count(*) as CountColumn from CRM.custprob c, CRM.probdefn d where resflag = 'N' and c.prob = d.probcode and @StartDate - probdttm &lt;= @NumberStart GROUP BY c.PROB, d.PROBDESC ORDER BY 1, 3"
