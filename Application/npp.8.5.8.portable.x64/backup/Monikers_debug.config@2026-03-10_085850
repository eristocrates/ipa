		<FAMILY nodeId="4317"
		        name="CRM">
			<COMPONENT nodeId="4318"
			           name="ServiceRequest"
			           file="CustomerService"
			           path="CRM">
				<ASSOC nodeId="4319">
					<ASSOCITEM nodeId="4320"
					           name="infoviewer"
					           value="Hansen.CRM.SRInfoViewerChildApplet"/>
				</ASSOC>
				<QUERIES nodeId="4321">
					<QUERY nodeId="4322"
					       name="PropertyOwner"
					       sql="select pc.cntctkey                from Property.ADDRESS a, Property.ADDRPRCL ap, Property.PRCLCNTC pc, Resources.CONTACT c                where a.addrkey = ap.addrkey and ap.prclkey = pc.prclkey and pc.primown = 'Y'                  and pc.expflag = 'N' and ( pc.ownfromdt &lt; GETDATE() or pc.ownfromdt is null )                   and (pc.owntodt &gt; GETDATE() or pc.owntodt is null)                  and pc.cntctkey = c.cntctkey and a.addrkey = @AddrKey                  order by pc.ownperc desc"
					       accid="0"
					       oracle="select pc.cntctkey                 from Property.ADDRESS a, Property.ADDRPRCL ap, Property.PRCLCNTC pc, Resources.CONTACT c                 where a.addrkey = ap.addrkey and ap.prclkey = pc.prclkey and pc.primown = 'Y'                   and pc.expflag = 'N' and (pc.ownfromdt &lt; SysDate or pc.ownfromdt is null)                    and (pc.owntodt &gt; SysDate or pc.owntodt is null)                   and pc.cntctkey = c.cntctkey and a.addrkey = ?                 order by pc.ownperc desc">
						<PARAM nodeId="4323"
						       name="AddrKey"
						       sql="@AddrKey"/>
					</QUERY>
					<QUERY nodeId="4324"
					       name="TotalOpenServiceRequests"
					       sql="SELECT COUNT( CUSTPROB.SERVNO ) FROM CRM.CUSTPROB CUSTPROB WHERE RESFLAG = 'N' AND CUSTPROB.SERVNO != 1"
					       accid="0"/>
					<QUERY nodeId="4325"
					       name="OpenServiceRequests"
					       sql="SELECT CUSTPROB.SERVNO FROM CRM.CUSTPROB CUSTPROB WHERE RESFLAG = 'N' AND CUSTPROB.SERVNO != 1"
					       accid="0"/>
					<QUERY nodeId="4326"
					       name="TotalUnassignedOpenServiceRequests"
					       sql="SELECT COUNT( CUSTPROB.SERVNO ) FROM CRM.CUSTPROB CUSTPROB WHERE RESFLAG = 'N' AND CUSTPROB.SERVNO != 1 AND CUSTPROB.RESP is NULL"
					       accid="0"/>
					<QUERY nodeId="4327"
					       name="UnassignedOpenServiceRequests"
					       sql="SELECT CUSTPROB.SERVNO FROM CRM.CUSTPROB CUSTPROB WHERE RESFLAG = 'N' AND CUSTPROB.SERVNO != 1 AND CUSTPROB.RESP is NULL"
					       accid="0"/>
					<QUERY nodeId="4328"
					       name="OpenServiceRequestsByResponsibility"
					       sql="SELECT COUNT( CUSTPROB.SERVNO ), CRMRESPONSIBILITY.DESCRIPT, CUSTPROB.RESP FROM CRM.CUSTPROB CUSTPROB, CRM.CRMRESPONSIBILITY CRMRESPONSIBILITY WHERE CUSTPROB.RESP = CRMRESPONSIBILITY.CODE AND RESFLAG = 'N' AND CUSTPROB.SERVNO != 1 AND CUSTPROB.RESP != '' GROUP BY CRMRESPONSIBILITY.DESCRIPT, CUSTPROB.RESP ORDER BY COUNT( CUSTPROB.SERVNO ) DESC"
					       accid="0"/>
					<QUERY nodeId="4329"
					       name="OpenServiceRequestsPerResponsibility"
					       sql="SELECT CUSTPROB.SERVNO FROM CRM.CUSTPROB CUSTPROB WHERE RESFLAG = 'N' AND CUSTPROB.SERVNO != 1 AND CUSTPROB.RESP = @itemKey"
					       accid="0"/>
					<QUERY nodeId="4330"
					       name="OpenServiceRequestsByType"
					       sql="SELECT COUNT( CUSTPROB.SERVNO ), PROBDEFN.PROBCODE, PROBDEFN.PROBKEY FROM CRM.CUSTPROB CUSTPROB, CRM.PROBDEFN PROBDEFN WHERE CUSTPROB.PROB = PROBDEFN.PROBKEY AND RESFLAG = 'N' AND CUSTPROB.SERVNO != 1 GROUP BY PROBDEFN.PROBCODE, PROBDEFN.PROBKEY ORDER BY COUNT( CUSTPROB.SERVNO ) DESC"
					       accid="0"/>
					<QUERY nodeId="4331"
					       name="OpenServiceRequestsPerType"
					       sql="SELECT CUSTPROB.SERVNO FROM CRM.CUSTPROB CUSTPROB WHERE CUSTPROB.PROB = @itemKey AND RESFLAG = 'N' AND CUSTPROB.SERVNO != 1"
					       accid="0"/>
				</QUERIES>
