					<QUERY nodeId="4755"
					       name="OutstandingDebtReport"
					       sql="Select a.blitemtype,sum(b.tranamt) as SUMCOLUMN from Billing.blitem a,Billing.ACCTTRAN b where a.blkey in(select blkey from Billing.custbl where paidstat='N' and stg5prckey &gt; 1 and bldate &gt;= @StartDate and bldate &lt;= @EndDate ) AND a.BLITEMKEY = b.BLITEMKEY group by a.blitemtype"
