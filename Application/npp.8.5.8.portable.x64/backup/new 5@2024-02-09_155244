SELECT PA.STNO, PA.PREDIR, PA.STNAME, PA.SUFFIX, RCO.ADDR1, RCO.STATE, RCO.ZIP, RCO.CONTACTTYPE, RCO.EVEPHN, RCO.DAYPHN, RCO.IDKEY, PA.OPTA, PA.OPTB, PA.SUFFIX
FROM PROPERTY.ADDRESS PA
INNER JOIN RESOURCOES.CONTACT RCO ON PA.STNO + PA.PREDIR + PA.STNAME + PA.SUFFIX = RCO.ADDR1
INNER JOIN RESOURCOES.CNTCTID