        rdf:type      infor:query;
        infor:accid   0;
        infor:name    "IncompleteInspectionsByResponsibility";
        infor:nodeId  5163;
        infor:sql     "SELECT COUNT( BLDGINSP.APBLDGINSPKEY ), CNTCTID.FULLNAME, BLDGINSP.ASSIGNTO FROM CDR_Building.BLDGINSP BLDGINSP, RESOURCES.CNTCTID CNTCTID, RESOURCES.CONTACT CONTACT, RESOURCES.EMPLOYEE EMPLOYEE WHERE BLDGINSP.ASSIGNTO = EMPLOYEE.EMPID AND EMPLOYEE.CONTACTKEY = CONTACT.CNTCTKEY AND CNTCTID.IDKEY = CONTACT.IDKEY AND ( BLDGINSP.RESULT IS NULL OR BLDGINSP.RESULT = ' ' ) AND BLDGINSP.APBLDGINSPKEY <> 1 AND BLDGINSP.ASSIGNED = 'Y'  AND BLDGINSP.ASSIGNTO <> ' ' GROUP BY BLDGINSP.ASSIGNTO, CNTCTID.FULLNAME ORDER BY COUNT( BLDGINSP.APBLDGINSPKEY ) DESC" .

