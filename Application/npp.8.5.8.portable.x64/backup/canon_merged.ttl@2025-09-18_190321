        infor:sql     "select sum(tranamt) as SUM30,'1' as COLUMN1  from Billing.ACCTTRAN where blkey in (select blkey from Billing.custbl where paidstat='N' and stg4prckey > 1 and  @StartDate - bldate >= 30 and @StartDate  - bldate < 60) UNION select sum(tranamt),'2' as COLUMN1 from Billing.ACCTTRAN where blkey in (select blkey from Billing.custbl where paidstat='N' and stg4prckey > 1 and  @StartDate - bldate >=60 and @StartDate  - bldate < 90) UNION select sum(tranamt),'3' as COLUMN1 from Billing.ACCTTRAN where blkey in (select blkey from Billing.custbl where paidstat='N' and stg4prckey > 1 and  @StartDate - bldate >=90 and @StartDate  - bldate < 120) UNION select sum(tranamt),'4' as COLUMN1 from Billing.ACCTTRAN where blkey in (select blkey from Billing.custbl where paidstat='N' and stg4prckey > 1 and  @StartDate - bldate >=120) ORDER BY COLUMN1";
