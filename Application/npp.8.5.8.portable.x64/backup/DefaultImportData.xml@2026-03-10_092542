			        CATEGORY="1014"
			        CODE="'Sample for processing all entries staged in the ION Import table for &quot;Journal&quot; nouns.  The noun and verb must match a defined mapping in the Messaging configuration&#xD;&#xA;        Try&#xD;&#xA;            Hansen.Core.Messaging.MessagingManagerFactory.Instance.ProcessImports(&quot;Journal&quot;, Hansen.Core.Messaging.MessageVerb.Sync)&#xD;&#xA;        Catch ex As Exception&#xD;&#xA;            Dim res As New Result(0, ResultSeverity.Error, ex)&#xD;&#xA;            Throw New ResultException(res)&#xD;&#xA;        End Try&#xD;&#xA;&#xD;&#xA;        Return Result.Success"/>
