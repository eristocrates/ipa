			<record name="WorkManagementXMilestoneXAdvanceMSFormula"
			        EVENTKEY="1788"
			        PRODFAMILYNAME="WorkManagement"
			        BUSOBJNAME="Milestone"
			        PAGENAME=""
			        NAME="AdvanceMSFormula"
			        NAMESPACE="WorkManagement"
			        METHODPREFIX="MSF"
			        METHODSIGNATURE="out System.String NextMilestone,  Hansen.WorkManagement.IWorkOrder oWorkOrder"
			        DEFAULTDLLNAME="WorkManagement"
			        DEFAULTCOMMENT="This method makes the WorkOrder object '&lt;b&gt;oWorkOrder&lt;/b&gt;' available to be used in your calculation to set a &lt;i&gt;System.String&lt;/i&gt; object named '&lt;b&gt;NextMilestone&lt;/b&gt;'. &lt;br&gt;&lt;br&gt;The purpose of this event it to determine if the requirements of the current Milestone have been fulfilled. If the requirements have been fulfilled, the &lt;span style='color:blue'&gt;next Milestone code&lt;/span style='color:blue'&gt; should be returned.&lt;br&gt;&lt;br&gt;Example Formulas:&lt;br&gt;&lt;b&gt;Example 1&lt;/b&gt;&lt;br&gt;if( oWorkOrder.Asset.Location = &quot;Front Lawn&quot; ) then&lt;br&gt;   NextMilestone = &quot;Overseed&quot;&lt;br&gt;else&lt;br&gt;   NextMilestone = &quot;ApplyFertilizer&quot;&lt;br&gt;end if&lt;br&gt;&lt;br&gt;&lt;b&gt;Example 2&lt;/b&gt; - This example first checks that all Status Checks have been satisfied and also no pending approvals exist.&lt;br&gt;Dim bStatusChecksSatisfied As Boolean&#xD;&#xA;&lt;br&gt;Dim res As Result&lt;br&gt;res = oWorkOrder.ProcessStatusChecks (bStatusChecksSatisfied)&lt;br&gt;if ( res.IsSuccess and bStatusChecksSatisfied ) then        &lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;if ( oWorkOrder.IsWorkStarted ) then               &lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;NextMilestone = &quot;B&quot;        &lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;else               &lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;NextMilestone = &quot;C&quot;        &lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;end if&lt;br&gt;end if&lt;br&gt;return res"/>
			<record name="WorkManagementXStatusCheckXCheckSCFormula"
			        EVENTKEY="1789"
			        PRODFAMILYNAME="WorkManagement"
			        BUSOBJNAME="StatusCheck"
			        PAGENAME=""
			        NAME="CheckSCFormula"
			        NAMESPACE="WorkManagement"
			        METHODPREFIX="MSC"
			        METHODSIGNATURE="out System.Boolean bIsSatisfied,  Hansen.WorkManagement.IWorkOrder oWorkOrder"
			        DEFAULTDLLNAME="WorkManagement"
			        DEFAULTCOMMENT="This method makes the WorkOrder object '&lt;b&gt;oWorkOrder&lt;/b&gt;' available to be used in your calculation to set a &lt;i&gt;System.Boolean&lt;/i&gt; object named '&lt;b&gt;bIsSatisfied&lt;/b&gt;'. &lt;br&gt;&lt;br&gt;The purpose of this event is to determine if the requirements of a Status Check have been satisfied. A return value of &lt;span style='color:blue'&gt;True&lt;/span style='color:blue'&gt; will flag the Status Check as being satisfied on the Work Order form.&lt;br&gt;&lt;br&gt; Example Formula:&lt;br&gt;if( oWorkOrder.BudgetNumber.Code = &quot;Spring2004&quot; ) then&lt;br&gt;   bIsSatisfied = true&lt;br&gt;else&lt;br&gt;   bIsSatisfied = false&lt;br&gt;end if"/>
