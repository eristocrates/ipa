			        DESCRIPTION="Sends a notification to the default for an inspection.  The default contact is specified as the primary applicant on the inspection's application.  This notification type should have an associated notification template to provide the message body since no custom message is provided in this code sample.  "
			        CATEGORY="1028"
			        CODE="'Send notification of type &quot;TYPE_NAME&quot;.  Since a contact isn't specified, the notification will be sent to the default for an inspection, which is the primary applicant on the application.  Note that if a template is not defined, the notification will be blank since no message was provided.&#xD;&#xA;return Hansen.Resources.Notifications.NotificationService.Send(&quot;TYPE_NAME&quot;, oInspection)"/>
			<record name="1076"
			        SNIPPETKEY="1076"
			        NAME="Open311 Match Address"
			        DESCRIPTION="Match an address submitted through Open311 to an IPS address record.  This example uses ArcGIS to validate and parse the address string."
			        CATEGORY="1029"
			        CODE="Dim res as result&#xD;&#xA;res = result.Success&#xD;&#xA;Dim matchedAddress as Hansen.Property.IAddress&#xD;&#xA;matchedAddress = ServerApplication.NewComponent(&quot;Hansen.Property.Address&quot;, requestContext.ServiceRequest.UserInfo)&#xD;&#xA;  &#xD;&#xA;Dim addressInput = requestContext.request.Element(&quot;address_string&quot;).Value&#xD;&#xA;  &#xD;&#xA;'Validate Address using ArcGIS&#xD;&#xA;Dim val As String = &quot;&quot;&#xD;&#xA;Dim url As String = &quot;http://geocode.arcgis.com/arcgis/rest/services/World/GeocodeServer/find?text=&quot; + addressInput + &quot;&amp;outFields=*&amp;f=pjson&quot;&#xD;&#xA;Dim newReq As System.Net.HttpWebRequest = DirectCast(System.Net.WebRequest.Create(url), System.Net.HttpWebRequest)&#xD;&#xA;newReq.Method = &quot;GET&quot;&#xD;&#xA;&#xD;&#xA;Dim newResp As System.Net.HttpWebResponse = DirectCast(newReq.GetResponse, System.Net.HttpWebResponse)&#xD;&#xA;If (newResp.StatusCode = Net.HttpStatusCode.OK) Then&#xD;&#xA;	Using myResponseStream As System.IO.Stream = newResp.GetResponseStream&#xD;&#xA;		Using myStreamReader As New IO.StreamReader(myResponseStream, System.Text.Encoding.UTF8)&#xD;&#xA;			val = myStreamReader.ReadToEnd&#xD;&#xA;		End Using&#xD;&#xA;	End Using &#xD;&#xA;End If&#xD;&#xA;&#xD;&#xA;'Parse ArcGIS Validation results&#xD;&#xA;if (val.Length &gt; 0) then&#xD;&#xA;	Dim StNo As String = &quot;&quot;&#xD;&#xA;	Dim StName As String = &quot;&quot;&#xD;&#xA;	Dim StType As String = &quot;&quot;&#xD;&#xA;	Dim Postal As String = &quot;&quot;&#xD;&#xA;	Dim City As String = &quot;&quot;&#xD;&#xA;	Dim State As String = &quot;&quot;&#xD;&#xA;	Dim pos As Integer = 0&#xD;&#xA;&#xD;&#xA;	pos = Microsoft.VisualBasic.InStr(val, &quot;AddNum&quot;)&#xD;&#xA;	If (pos &gt; 0) Then&#xD;&#xA;		Dim workingCopy = val.Substring(pos + 8)&#xD;&#xA;		Dim comma = Microsoft.VisualBasic.InStr(workingCopy, &quot;,&quot;)&#xD;&#xA;		If (comma &gt; 0) Then&#xD;&#xA;			StNo = workingCopy.Substring(0, comma - 1).Replace(&quot;&quot;&quot;&quot;, &quot; &quot;).Trim()&#xD;&#xA;		End If&#xD;&#xA;	End If&#xD;&#xA;&#xD;&#xA;	pos = Microsoft.VisualBasic.InStr(val, &quot;StName&quot;)&#xD;&#xA;	If (pos &gt; 0) Then&#xD;&#xA;		Dim workingCopy = val.Substring(pos + 8)&#xD;&#xA;		Dim comma = Microsoft.VisualBasic.InStr(workingCopy, &quot;,&quot;)&#xD;&#xA;		If (comma &gt; 0) Then&#xD;&#xA;			StName = workingCopy.Substring(0, comma - 1).Replace(&quot;&quot;&quot;&quot;, &quot; &quot;).Trim()&#xD;&#xA;		End If&#xD;&#xA;	End If&#xD;&#xA;&#xD;&#xA;	pos = Microsoft.VisualBasic.InStr(val, &quot;StType&quot;)&#xD;&#xA;	If (pos &gt; 0) Then&#xD;&#xA;		Dim workingCopy = val.Substring(pos + 8)&#xD;&#xA;		Dim comma = Microsoft.VisualBasic.InStr(workingCopy, &quot;,&quot;)&#xD;&#xA;		If (comma &gt; 0) Then&#xD;&#xA;			StType = workingCopy.Substring(0, comma - 1).Replace(&quot;&quot;&quot;&quot;, &quot; &quot;).Trim()&#xD;&#xA;		End If&#xD;&#xA;	End If&#xD;&#xA;&#xD;&#xA;	pos = Microsoft.VisualBasic.InStr(val, &quot;City&quot;)&#xD;&#xA;	If (pos &gt; 0) Then&#xD;&#xA;		Dim workingCopy = val.Substring(pos + 6)&#xD;&#xA;		Dim comma = Microsoft.VisualBasic.InStr(workingCopy, &quot;,&quot;)&#xD;&#xA;		If (comma &gt; 0) Then&#xD;&#xA;			City = workingCopy.Substring(0, comma - 1).Replace(&quot;&quot;&quot;&quot;, &quot; &quot;).Trim()&#xD;&#xA;		End If&#xD;&#xA;	End If&#xD;&#xA;&#xD;&#xA;	pos = Microsoft.VisualBasic.InStr(val, &quot;Region&quot;)&#xD;&#xA;	If (pos &gt; 0) Then&#xD;&#xA;		Dim workingCopy = val.Substring(pos + 8)&#xD;&#xA;		Dim comma = Microsoft.VisualBasic.InStr(workingCopy, &quot;,&quot;)&#xD;&#xA;		If (comma &gt; 0) Then&#xD;&#xA;			State = workingCopy.Substring(0, comma - 1).Replace(&quot;&quot;&quot;&quot;, &quot; &quot;).Trim()&#xD;&#xA;		End If&#xD;&#xA;	End If&#xD;&#xA;&#xD;&#xA;	pos = Microsoft.VisualBasic.InStr(val, &quot;Postal&quot;)&#xD;&#xA;	If (pos &gt; 0) Then&#xD;&#xA;		Dim workingCopy = val.Substring(pos + 8)&#xD;&#xA;		Dim comma = Microsoft.VisualBasic.InStr(workingCopy, &quot;,&quot;)&#xD;&#xA;		If (comma &gt; 0) Then&#xD;&#xA;			Postal = workingCopy.Substring(0, comma - 1).Replace(&quot;&quot;&quot;&quot;, &quot; &quot;).Trim()&#xD;&#xA;		End If&#xD;&#xA;	End If&#xD;&#xA;&#xD;&#xA;	' Address Lookup&#xD;&#xA;	Dim oWhere as DBOperativeCollection = new DBOperativeCollection()&#xD;&#xA;	oWhere.Add( new IDOperativeByCommonID( &quot;Property&quot;, &quot;Address.StreetNumber&quot;, ComparisonOperator.Equal, StNo ) )&#xD;&#xA;	oWhere.Add( new IDOperativeByCommonID( &quot;Property&quot;, &quot;Address.StreetName&quot;, ComparisonOperator.Equal, StName ) )&#xD;&#xA;	oWhere.Add( new IDOperativeByCommonID( &quot;Property&quot;, &quot;Address.Suffix&quot;, ComparisonOperator.Equal, StType ) )&#xD;&#xA;	oWhere.Add( new IDOperativeByCommonID( &quot;Property&quot;, &quot;Address.City&quot;, ComparisonOperator.Equal, City ) )&#xD;&#xA;	oWhere.Add( new IDOperativeByCommonID( &quot;Property&quot;, &quot;Address.Zip&quot;, ComparisonOperator.Equal, Postal ) )&#xD;&#xA;	res += matchedAddress.Load( oWhere )&#xD;&#xA;	if (res.IsSuccess AndAlso res.IsNoDataFound = false AndAlso res.Code &lt;&gt; ResultCodes.Component.BadRowCount) Then&#xD;&#xA;		address = matchedAddress&#xD;&#xA;	End if&#xD;&#xA;End If&#xD;&#xA;	&#xD;&#xA;return res"/>
			<record name="1077"
			        SNIPPETKEY="1077"
			        NAME="Open311 Status Notes"
			        DESCRIPTION="Returns a custom string as status notes for an Open311 request."
			        CATEGORY="1029"
			        CODE="' This simple example demonstrates the ability to return custom status notes for an Open311 request&#xD;&#xA;Dim sb As New System.Text.StringBuilder()&#xD;&#xA;&#xD;&#xA;sb.AppendLine(&quot;Status Notes added by a formula!&quot;)&#xD;&#xA;&#xD;&#xA;if (requestContext.ServiceRequest.IsAssigned) then&#xD;&#xA;  sb.AppendLine(&quot;Assigned&quot;)&#xD;&#xA;else&#xD;&#xA;  sb.AppendLine(&quot;Not Assigned&quot;)&#xD;&#xA;end if&#xD;&#xA;&#xD;&#xA;if (requestContext.ServiceRequest.HasWO) then&#xD;&#xA;  sb.AppendLine(&quot;Has Work Orders&quot;)&#xD;&#xA;else&#xD;&#xA;  sb.AppendLine(&quot;No Work Orders&quot;)&#xD;&#xA;end if&#xD;&#xA;&#xD;&#xA;statusNotes = sb.ToString"/>
			<record name="1078"
			        SNIPPETKEY="1078"
			        NAME="Open311 Request"
			        DESCRIPTION="Demonstrates the ability to manipulate the Open311 request."
			        CATEGORY="1029"
			        CODE="' Open311Request&#xD;&#xA;Dim child3 As System.Xml.Linq.XElement&#xD;&#xA;Dim msg as System.String&#xD;&#xA;Dim newRequestIds as System.String&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;responseContext = requestContext&#xD;&#xA;&#xD;&#xA;' Append another service request to the query by adding to the xml request!&#xD;&#xA;if (requestContext.RequestType = Hansen.CRM.Open311.Open311RequestType.GETSERVICEREQUEST)&#xD;&#xA;  child3 = responseContext.Request.&lt;service_request_id&gt;(0)&#xD;&#xA;  newRequestIds = &quot;&lt;service_request_id&gt;&quot; + child3.Value.ToString() + &quot;,1001&quot; + &quot;&lt;/service_request_id&gt;&quot;&#xD;&#xA;  Dim newChild as System.Xml.Linq.XElement = System.Xml.Linq.XElement.Parse(newRequestIds)&#xD;&#xA;  child3.ReplaceWith(newChild)&#xD;&#xA;  &#xD;&#xA;  msg = &quot;Changed the request to: &quot; + newRequestIds&#xD;&#xA;End if&#xD;&#xA;&#xD;&#xA;if (requestContext.RequestType = Hansen.CRM.Open311.Open311RequestType.GETSERVICEREQUESTS)&#xD;&#xA;  ' Append a filter to the query by adding to the AdditionalFilters DbOperativeCollection&#xD;&#xA;  ' This example will limit the results to Open service requests&#xD;&#xA;  Dim where as DBOperativeCollection = new DBOperativeCollection&#xD;&#xA;  Dim op as IDOperativeByCommonID = new IDOperativeByCommonID(&quot;CRM&quot;,&quot;ServiceRequest.IsResolved&quot;, ComparisonOperator.Equal, &quot;N&quot;)&#xD;&#xA;  where.Add(op)&#xD;&#xA;  responseContext.AdditionalFilters = where&#xD;&#xA;end if&#xD;&#xA;&#xD;&#xA;Dim res as result&#xD;&#xA;res = New Result(0, ResultSeverity.UserWarning, msg)&#xD;&#xA;&#xD;&#xA;Return res"/>
			<record name="1079"
			        SNIPPETKEY="1079"
			        NAME="Open311 Response"
			        DESCRIPTION="Demonstrates the ability to extend the Open311 response."
			        CATEGORY="1029"
			        CODE="' This example extends the standard Open311Response if Extensions = true in the request&#xD;&#xA;&#xD;&#xA;' Copy the response from the request &#xD;&#xA;responseContext = requestContext&#xD;&#xA;&#xD;&#xA;if ((requestContext.RequestType = Hansen.CRM.Open311.Open311RequestType.GETSERVICEREQUEST) OrElse&#xD;&#xA;    (requestContext.RequestType = Hansen.CRM.Open311.Open311RequestType.GETSERVICEREQUESTS)) then&#xD;&#xA;  if (requestContext.Extensions = true) then&#xD;&#xA;&#xD;&#xA;   &#xD;&#xA;    ' Extend the standard IPS response&#xD;&#xA;    Dim xmlExtension As System.Xml.Linq.XElement = _&#xD;&#xA;    &lt;Open311Extension&gt;&#xD;&#xA;    	&lt;NewElement&gt;Extended Request Information&lt;/NewElement&gt;&#xD;&#xA;    &lt;/Open311Extension&gt;&#xD;&#xA;    &#xD;&#xA;    responseContext.Response.Add(xmlExtension)&#xD;&#xA;  end if&#xD;&#xA;end if"/>
			<record name="1080"
			        SNIPPETKEY="1080"
			        NAME="ION File Export"
			        DESCRIPTION="Sample on how to export a file to IPS Messaging System directly from a physical location"
			        CATEGORY="1014"
			        CODE="'Import a custom BOD to IPS Messaging System directly from a raw file&#xD;&#xA;&#xD;&#xA;Dim res As Result = Result.Success&#xD;&#xA;Dim file As String&#xD;&#xA;&#xD;&#xA;'Select full path and filename from physical location (e.g. S3)  ex: Custom\CustomBOD.txt'&#xD;&#xA;file = &quot;&quot;&#xD;&#xA;&#xD;&#xA;res = Hansen.Core.Messaging.MessagingService.SendFile( file )&#xD;&#xA;&#xD;&#xA;Return res"/>
			<record name="1081"
			        SNIPPETKEY="1081"
			        NAME="Create Directory"
			        DESCRIPTION="Create a directory."
