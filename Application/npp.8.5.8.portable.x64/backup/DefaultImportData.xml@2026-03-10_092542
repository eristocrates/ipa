			        CODE="Dim result as Result = Result.Success  &#xD;&#xA;&#xD;&#xA;Dim reportName = &quot;GrossIncomeReportingForm&quot; 'This is the name of the report under General Reports.&#xD;&#xA;Dim edmProviderName = &quot;Infor Document Management&quot; 'Name of the IDM provider in EDM Setup.&#xD;&#xA;Dim documentType = &quot;IPS&quot; 'The name of the document type to upload the generated report output too.&#xD;&#xA;&#xD;&#xA;Dim reportRequest = new Hansen.Core.Report.Management.ReportRequest()&#xD;&#xA; &#xD;&#xA;Dim application = ServerApplication.NewComponent(Of Hansen.CDR.Use.IUseApplication)&#xD;&#xA;application.PrimaryKey = oUseApplication.UseApplicationKey&#xD;&#xA;result = application.LoadByKey()&#xD;&#xA;result.Assert()&#xD;&#xA;&#xD;&#xA;reportRequest.Name = reportName&#xD;&#xA;reportRequest.ExportType = &quot;DOCX&quot;&#xD;&#xA;reportRequest.Parameters.Add(&quot;ApplicationName&quot;, application.ApplicationName)&#xD;&#xA;reportRequest.Parameters.Add(&quot;ApplicationNumber&quot;, application.ApplicationNumber)&#xD;&#xA;&#xD;&#xA;Dim reportService = ServerApplication.Resolve(Of Hansen.Core.Report.Management.IReportManagementService)&#xD;&#xA;Dim reportResponse As Hansen.Core.Report.Management.ReportResponse = reportService.Generate(reportRequest)&#xD;&#xA;&#xD;&#xA;Dim documentService As Hansen.Core.DocumentManagement.Services.IDocumentService = ServerApplication.Resolve(Of Hansen.Core.DocumentManagement.Services.IDocumentService)()&#xD;&#xA;Dim docReq As Hansen.Core.DocumentManagement.Services.AddDocumentRequest = New Hansen.Core.DocumentManagement.Services.AddDocumentRequest()&#xD;&#xA;Dim docResponse as Hansen.Core.DocumentManagement.Services.DocumentResponse = New Hansen.Core.DocumentManagement.Services.DocumentResponse()&#xD;&#xA;&#xD;&#xA;docReq.ProviderName = edmProviderName&#xD;&#xA;docReq.Parent = application&#xD;&#xA;&#xD;&#xA;docReq.DocumentType = New Hansen.Core.DocumentManagement.Services.DocumentTypeRequest&#xD;&#xA;docReq.DocumentType.Name = documentType&#xD;&#xA;docReq.Properties = New Hansen.Core.DocumentManagement.Services.DocumentPropertiesRequest&#xD;&#xA;docReq.Properties.Filename = reportResponse.Filename&#xD;&#xA;&#xD;&#xA;docReq.Properties.Title = &quot;Gross Invoice Reporting&quot;&#xD;&#xA;docReq.Properties.Description = &quot; Generated by Report&quot;&#xD;&#xA;&#xD;&#xA;Using memoryStream As New System.IO.MemoryStream()&#xD;&#xA;    reportResponse.OutputStream.CopyTo(memoryStream)&#xD;&#xA; &#xD;&#xA;    ' Create a new MemoryStream using the byte array&#xD;&#xA;    docReq.Stream =  New System.IO.MemoryStream(memoryStream.ToArray())  &#xD;&#xA;    docResponse = documentService.AddDocument(docReq)&#xD;&#xA;End Using&#xD;&#xA;&#xD;&#xA; &#xD;&#xA;Return result"/>
