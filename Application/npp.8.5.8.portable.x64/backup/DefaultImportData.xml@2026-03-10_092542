			<record name="1125"
			        SNIPPETKEY="1125"
			        NAME="Send to authorized users"
			        DESCRIPTION="Snippet for Sending Notifications to Organization's Authorized Users"
			        CATEGORY="1028"
			        CODE="' Formula for Sending Notifications to an Organization's Authorized Users when an Organization's Email Address is Not Available&#xD;&#xA;&#xD;&#xA;' Retrieve the primary contact &#xD;&#xA;Dim contact As Hansen.Resources.IContact = DirectCast(oInspection, Hansen.CDR.ICDRInspection).GetPrimaryContact()&#xD;&#xA;&#xD;&#xA;' Load the contact and check if it successfully loads&#xD;&#xA;Dim res As Result = contact.Load()&#xD;&#xA;If res.IsSuccess Then&#xD;&#xA;    ' Check if the contact has an email address&#xD;&#xA;    If Not String.IsNullOrEmpty(contact.EMailAddress) Then&#xD;&#xA;        ' Send the notification to the primary contact's email&#xD;&#xA;        Dim notificationResult As Result = Hansen.Resources.Notifications.NotificationService.Send(&#xD;&#xA;            &quot;Here is a message to embed in the template&quot;, &#xD;&#xA;            &quot;EmailTemplate&quot;, &#xD;&#xA;            &quot;TYPE_NAME&quot;, &#xD;&#xA;            contact)&#xD;&#xA;        Else&#xD;&#xA;        ' If no email, loop through the authorized users collection&#xD;&#xA;        For Each authorizedUser As Hansen.Portal.IAuthorizedUser In contact.AuthorizedUsers&#xD;&#xA;            ' Check if the user is an admin and if their invitation is accepted&#xD;&#xA;            If authorizedUser.IsAdmin AndAlso authorizedUser.InviteAcceptedDate &lt;&gt; Date.MinValue Then&#xD;&#xA;                ' Send the notification to the authorized users of that contact's (organization) email&#xD;&#xA;                Dim notificationResult As Result = Hansen.Resources.Notifications.NotificationService.Send(&#xD;&#xA;                    &quot;Here is a message to embed in the template&quot;, &#xD;&#xA;                    &quot;EmailTemplate&quot;, &#xD;&#xA;                    &quot;TYPE_NAME&quot;, &#xD;&#xA;                    authorizedUser.Membership.Contact)&#xD;&#xA;            End If&#xD;&#xA;        Next&#xD;&#xA;    End If&#xD;&#xA;Else&#xD;&#xA;    ' Handle failed contact load&#xD;&#xA;    Return New Result(-1, ResultSeverity.UserWarning, &quot;Failed to load contact details.&quot;)&#xD;&#xA;End If"/>
