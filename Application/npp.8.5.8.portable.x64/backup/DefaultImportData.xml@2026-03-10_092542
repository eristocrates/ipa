			        DEFAULTDLLNAME="CDRPlanning"
			        DEFAULTCOMMENT="&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;FONT size=2&gt;This event is defined to calculate the quantity of this at cost fee.&lt;SPAN style=&quot;mso-spacerun: yes&quot;&gt;&amp;nbsp; &lt;/SPAN&gt;The returned value needs to be set into the Quantity variable.&lt;SPAN style=&quot;mso-spacerun: yes&quot;&gt;&amp;nbsp; &lt;/SPAN&gt;In the following example, the quantity is the hour spent on the inspection for inspector Joe Smith.&lt;/FONT&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;?xml:namespace prefix = o ns = &quot;urn:schemas-microsoft-com:office:office&quot; /&gt;&lt;o:p&gt;&lt;FONT size=2&gt;&amp;nbsp;&lt;/FONT&gt;&lt;/o:p&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;FONT size=2&gt;Example: &lt;/FONT&gt;&lt;/P&gt;&lt;FONT size=2&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;Quantity = 0.00&lt;o:p&gt;&lt;/o:p&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;o:p&gt;&amp;nbsp;&lt;/o:p&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;Dim oInsp as Hansen.CDR.Planning.IInspection&lt;o:p&gt;&lt;/o:p&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;Dim dTotalHrs as decimal&lt;o:p&gt;&lt;/o:p&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;dTotalHrs = 0.0&lt;o:p&gt;&lt;/o:p&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;for each oInsp in oPlanningApp.Inspections&lt;o:p&gt;&lt;/o:p&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;mso-spacerun: yes&quot;&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;/SPAN&gt;if oInsp. InspectedBy.LastName.ToUpper() = &quot;SMITH&quot; and oInsp.InspectedBy.FirstName.ToUpper = “JOE” then &lt;o:p&gt;&lt;/o:p&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;mso-spacerun: yes&quot;&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;/SPAN&gt;dTotalHrs = dTotalHrs + oInsp.InspectionHours&lt;o:p&gt;&lt;/o:p&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;mso-spacerun: yes&quot;&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;/SPAN&gt;end if &lt;o:p&gt;&lt;/o:p&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;next oInsp&lt;o:p&gt;&lt;/o:p&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;o:p&gt;&amp;nbsp;&lt;/o:p&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;Quantity = dTotalHrs&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;/FONT&gt;&lt;/P&gt;"/>
