			        CATEGORY="1011"
			        CODE="'Fill in the x's with IAUAddress, ICAAddress, IGBAddress, IJPAddress, INZAddress, IUSAddress, or IZAAddress&#xD;&#xA;dim address as Hansen.Property.xxxxxx&#xD;&#xA;dim oServiceRequestLog&#xD;&#xA;'Anything not implemented by the global address interface IAddress must be casted CType to a locale specific address&#xD;&#xA;address = CType(oServiceRequestLog.ServiceRequest.Address, Hansen.Property.xxxxxx)&#xD;&#xA; &#xD;&#xA;dim streetName as string = address.StreetName&#xD;&#xA; &#xD;&#xA;dim suffix as string = address.Suffix.Code&#xD;&#xA; &#xD;&#xA;dim res as Hansen.Core.Result = new Result(0, ResultSeverity.UserError, &quot;street name =&quot; &amp; streetName &amp; &quot; suffix =&quot; &amp; suffix)&#xD;&#xA;return res"/>
			<record name="1035"
			        SNIPPETKEY="1035"
			        NAME="Modifying COMP Values"
			        DESCRIPTION="Syncs COMP table and derived table"
			        CATEGORY="1012"
			        CODE="'-----------------------------Snippet&#xD;&#xA;&#xD;&#xA;' Asset fields are a special case for workflow modifications.  When an asset is added or &#xD;&#xA;'updated in the system, the following sequence of events occurs.&#xD;&#xA;&#xD;&#xA;' 1) Add/Update is invoked on the Business Object &#xD;&#xA;' 2) System calls Asset.Add/Update (This modifies the COMP Table)&#xD;&#xA;' 3) System calls oTree.Add/Update (Modifies the derived Asset table.  e.g COMPTR)&#xD;&#xA;&#xD;&#xA;' While many comp properties are stored on the derived table, they are pulled from the &#xD;&#xA;'comp (Asset) business object for viewing.  Thus, when modifying properties on derived &#xD;&#xA;'object, the Asset MUST be updated before exiting the formula.  This allows the COMP &#xD;&#xA;'table to stay in sync with the derived table.&#xD;&#xA;&#xD;&#xA;'The properties this effects are Address, AddressQualifier, AddedBy, AssetType, &#xD;&#xA;'Complex, ExpireDate, ExpiredBy, ID, ID2, Intersection, LastModifiedBy, &#xD;&#xA;'LastModifiedDateTime, Mainline, MapNumber, ParallelLineNumber, Parcel, &#xD;&#xA;'RailCrossing, RailSegment, ServiceLine, StreetSegment, UnitDesc, UnitID2Asset, &#xD;&#xA;'UnitID2Type, UnitIDAsset, UnitIDType, UsageArea&#xD;&#xA;&#xD;&#xA;'---------------------------------Sample-----------------------&#xD;&#xA;&#xD;&#xA;dim res as Hansen.Core.Result&#xD;&#xA;'Modify the denormalized property&#xD;&#xA;oTree.UnitDesc = &quot;Sample Unit Description Modification&quot;&#xD;&#xA;res = oTree.Asset.Update()&#xD;&#xA;return res&#xD;&#xA;"/>
			<record name="1036"
			        SNIPPETKEY="1036"
			        NAME="ApplCalcFeeRateTblVal"
			        DESCRIPTION="Use the Application.CalcuateFeeRateTableValue method to evaluate rate table values."
			        CATEGORY="1009"
			        CODE="'Example on the usage of the Application.CalcuateFeeRateTableValue method primarily intended to be used in a situation &#xD;&#xA;'where a field in an agency grid detail is being used to evaluate the rate table.&#xD;&#xA;'Having a field in an agency grid detail (Mechanical Detail) being used to evaluate a rate table value, &#xD;&#xA;'sum the value returned by a rate table calculation for each agency grid detail record.&#xD;&#xA;&#xD;&#xA;Dim rateTableEffectiveDate as System.DateTime = System.DateTime.Now      ' &lt;&lt;Replace with the appropriate date to use to get the correct rate table&#xD;&#xA;Dim rateTableValueSum as Decimal = 0.0&#xD;&#xA;&#xD;&#xA;'Load the rate code by id&#xD;&#xA;Dim rateCode as Hansen.Resources.RateTable.IRateCode&#xD;&#xA;rateCode = ServerApplication.NewComponent (&quot;Hansen.Resources.RateTable.RateCode&quot;, oBuildingApp.UserInfo)&#xD;&#xA;If NOT (rateCode Is Nothing) then&#xD;&#xA;    rateCode.RateCode = &quot;Rate Code&quot;     '&lt;&lt;Replace with the appropriate rate code&#xD;&#xA;    rateCode.LoadByID()&#xD;&#xA;&#xD;&#xA;    If rateCode.RateCodeKey &gt; 1 then&#xD;&#xA;        'Process the agency grid details&#xD;&#xA;        Dim applicationDetail as Hansen.CDR.Building.IApplicationDetail&#xD;&#xA;        For each applicationDetail in oBuildingApp.ApplicationDetails&#xD;&#xA;            If applicationDetail.ApplicationDetailType.Description = &quot;Mechanical Detail&quot; AND res.IsSuccess&#xD;&#xA;                Dim agencyDetail as Hansen8.Mechanical.MechanicalDetail&#xD;&#xA;                agencyDetail = Hansen8.Mechanical.MechanicalDetail.GetInstanceFromParent (applicationDetail, res)&#xD;&#xA; &#xD;&#xA;                Dim gridDetail as Hansen8.Mechanical.MechDetailsGrid&#xD;&#xA;&#xD;&#xA;                For each gridDetail in agencyDetail.MechDetailsGridMechanicalDetail&#xD;&#xA;                    Dim returnedRateTableValue as Decimal = 0.0&#xD;&#xA;&#xD;&#xA;                    res = oBuildingApp.Application.CalculateFeeRateTableValue( returnedRateTableValue, rateCode.RateCodeKey, rateTableEffectiveDate, oBuildingApp, gridDetail )&#xD;&#xA;&#xD;&#xA;                    'Continue processing&#xD;&#xA;                    If ( res.IsSuccess ) then&#xD;&#xA;                        ' Add the value returned to the running total&#xD;&#xA;                        rateTableValueSum = rateTableValueSum + returnedRateTableValue&#xD;&#xA;                    else&#xD;&#xA;                        Exit For&#xD;&#xA;                    End if&#xD;&#xA;                Next&#xD;&#xA;            End if&#xD;&#xA;        Next&#xD;&#xA;    End if&#xD;&#xA;End if&#xD;&#xA;"/>
			<record name="1037"
			        SNIPPETKEY="1037"
			        NAME="FeeCalcFeeRateTblVal"
			        DESCRIPTION="Use the Fee.CalcuateFeeRateTableValue method to evaluate rate table values."
			        CATEGORY="1009"
			        CODE="'Example on the usage of the Fee.CalcuateRateTableValue method primarily intended to be used in a situation &#xD;&#xA;'where a field in an agency grid detail is being used to evaluate the rate table.&#xD;&#xA;'Having a field in an agency grid detail (Mechanical Detail) being used to evaluate a rate table value, &#xD;&#xA;'sum the value returned by a rate table calculation for each agency grid detail record.&#xD;&#xA;&#xD;&#xA;Dim rateTableEffectiveDate as System.DateTime = System.DateTime.Now      ' &lt;&lt;Replace with the appropriate date to use to get the correct rate table&#xD;&#xA;Dim rateTableValueSum as Decimal = 0.0&#xD;&#xA;&#xD;&#xA;'Load the rate code by id&#xD;&#xA;Dim rateCode as Hansen.Resources.RateTable.IRateCode&#xD;&#xA;rateCode = ServerApplication.NewComponent (&quot;Hansen.Resources.RateTable.RateCode&quot;, oBuildingApp.UserInfo)&#xD;&#xA;If NOT (rateCode Is Nothing) then&#xD;&#xA;    rateCode.RateCode = &quot;Rate Code&quot;     '&lt;&lt;Replace with the appropriate rate code&#xD;&#xA;    rateCode.LoadByID()&#xD;&#xA;&#xD;&#xA;    If rateCode.RateCodeKey &gt; 1 then&#xD;&#xA;        'Process the agency grid details&#xD;&#xA;        Dim applicationDetail as Hansen.CDR.Building.IApplicationDetail&#xD;&#xA;        For each applicationDetail in oBuildingApp.ApplicationDetails&#xD;&#xA;            If applicationDetail.ApplicationDetailType.Description = &quot;Mechanical Detail&quot; AND res.IsSuccess&#xD;&#xA;                Dim agencyDetail as Hansen8.Mechanical.MechanicalDetail&#xD;&#xA;                agencyDetail = Hansen8.Mechanical.MechanicalDetail.GetInstanceFromParent (applicationDetail, res)&#xD;&#xA; &#xD;&#xA;                Dim gridDetail as Hansen8.Mechanical.MechDetailsGrid&#xD;&#xA;&#xD;&#xA;                For each gridDetail in agencyDetail.MechDetailsGridMechanicalDetail&#xD;&#xA;                    Dim returnedRateTableValue as Decimal = 0.0&#xD;&#xA;&#xD;&#xA;                    res = Fee.CalculateRateTableValue( returnedRateTableValue, rateCode.RateCodeKey, rateTableEffectiveDate, oBuildingApp, gridDetail )&#xD;&#xA;&#xD;&#xA;                    'Continue processing&#xD;&#xA;                    If ( res.IsSuccess ) then&#xD;&#xA;                        ' Add the value returned to the running total&#xD;&#xA;                        rateTableValueSum = rateTableValueSum + returnedRateTableValue&#xD;&#xA;                    else&#xD;&#xA;                        Exit For&#xD;&#xA;                    End if&#xD;&#xA;                Next&#xD;&#xA;            End if&#xD;&#xA;        Next&#xD;&#xA;    End if&#xD;&#xA;End if&#xD;&#xA;"/>
