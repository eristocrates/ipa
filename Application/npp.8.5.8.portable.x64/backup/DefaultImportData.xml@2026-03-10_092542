			        NAMESPACE="CDR.TradeLicense"
			        METHODPREFIX="CV"
			        METHODSIGNATURE="Hansen.CDR.TradeLicense.ITradeLicense oTradeLicense"
			        DEFAULTDLLNAME="TradeLicense"
			        DEFAULTCOMMENT="&lt;P&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;This event is defined to custom validate data entered by the user.&amp;nbsp; Most of the time, this event is invoked when user leaves the current page&amp;nbsp;to prevent them from going foward if invalid data is entered.&lt;?xml:namespace prefix = o ns = &quot;urn:schemas-microsoft-com:office:office&quot; /&gt;&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;In this example, the&amp;nbsp;license type&amp;nbsp;&quot;MasterELE&quot;&amp;nbsp;only accepts&amp;nbsp;normal priority, not high or low.&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;Dim res as Hansen.Core.Result = Result.Success&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;if oTradeLicense.LicenseType.LicenseType = &quot;MasterELE&quot; Then&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;if oTradeLicense.Priority.Code = &quot;High&quot;&amp;nbsp;or oTradeLicense.Priority.Code = &quot;Low&quot;&amp;nbsp;Then&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;res = new Result(1, ResultSeverity.UserError, &quot;High or Low is not valid Priority code for this license type&quot;)&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;End If&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;End If&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;return res&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&lt;FONT style=&quot;BACKGROUND-COLOR: #808080&quot;&gt;&lt;/FONT&gt;&amp;nbsp;&lt;/P&gt;&lt;/P&gt;"/>
			<record name="CDR.UseXUseApplicationXCustomValidate"
			        EVENTKEY="2282"
			        PRODFAMILYNAME="CDR.Use"
			        BUSOBJNAME="UseApplication"
			        PAGENAME=""
			        NAME="CustomValidate"
			        NAMESPACE="CDR.Use"
			        METHODPREFIX="CV"
			        METHODSIGNATURE="Hansen.CDR.Use.IUseApplication oUseApplication"
			        DEFAULTDLLNAME="CDRUse"
			        DEFAULTCOMMENT="&lt;P&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;This event is defined to custom validate data entered by the user.&amp;nbsp; Most of the time, this event is invoked when user leaves the current page&amp;nbsp;to prevent them from going foward if invalid data is entered.&lt;?xml:namespace prefix = o ns = &quot;urn:schemas-microsoft-com:office:office&quot; /&gt;&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;In this example, the&amp;nbsp;application type&amp;nbsp;&quot;Elevator&quot; does not accept&amp;nbsp;high priority.&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;Dim res as Hansen.Core.Result = Result.Success&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;if oUseApplication.ApplicationType.ApplicationType = &quot;Elevator&quot; Then&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;if oUseApplication.Priority.Code = &quot;High&quot; Then&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;res = new Result(1, ResultSeverity.UserError, &quot;High is not valid Priority code for this&amp;nbsp;application type&quot;)&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;End If&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;End If&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;SPAN style=&quot;FONT-FAMILY: Arial&quot;&gt;return res&lt;o:p&gt;&lt;/o:p&gt;&lt;/SPAN&gt;&lt;/P&gt;"/>
			<record name="AssetManagementXAssetInspectionIndexXWorkOrderIndexCalc"
			        EVENTKEY="2283"
			        PRODFAMILYNAME="AssetManagement"
			        BUSOBJNAME="AssetInspectionIndex"
			        PAGENAME=""
			        NAME="WorkOrderIndexCalc"
			        NAMESPACE="AssetManagement"
			        METHODPREFIX="WOCI"
			        METHODSIGNATURE="out System.Double IndexRating, Hansen.WorkManagement.IWorkOrder oWorkOrder, System.Double IndexValue, System.DateTime IndexDate, System.Double DeterioratedValue"
			        DEFAULTDLLNAME="AssetManagement"
			        DEFAULTCOMMENT="&lt;P&gt;This formula is used&amp;nbsp; to calculate an inspection index&amp;nbsp;based off a work order.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&lt;STRONG&gt;The following parameters are available to use&lt;/STRONG&gt;:&lt;BR&gt;&lt;FONT color=#ff0000&gt;oWorkOrder&lt;/FONT&gt; - The&amp;nbsp;work order&amp;nbsp;business object.&amp;nbsp;&lt;BR&gt;&lt;FONT color=#ff0000&gt;IndexValue&amp;nbsp; &lt;FONT color=#000000&gt;- The last measured/calculated value for this index for the asset associated to this work order.&lt;BR&gt;&lt;/FONT&gt;IndexDate &lt;FONT color=#000000&gt;- The date the IndexValue was recorded.&lt;BR&gt;&lt;/FONT&gt;DeterioratedValue &lt;/FONT&gt;&lt;FONT color=#000000&gt;- The deteriorated value based on the IndexValue and the Curve specified for this Index.&lt;BR&gt;&lt;/FONT&gt;&lt;FONT color=#ff0000&gt;IndexRating&lt;/FONT&gt; - The calculated index should be assigned to this System.Double parameter.&lt;/P&gt;"/>
			<record name="AssetManagementXAssetInspectionIndexXPredictionCurveFormular"
			        EVENTKEY="2284"
			        PRODFAMILYNAME="AssetManagement"
			        BUSOBJNAME="AssetInspectionIndex"
			        PAGENAME=""
			        NAME="PredictionCurveFormular"
			        NAMESPACE="AssetManagement"
			        METHODPREFIX="PCCALC"
			        METHODSIGNATURE="out System.String curve, Hansen.AssetManagement.IAsset oAsset"
			        DEFAULTDLLNAME="AssetManagement"
			        DEFAULTCOMMENT="&lt;P&gt;This formula is used&amp;nbsp; to determine which deterioration curve to use to caluclate the deteriorated value for this index.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&lt;STRONG&gt;The following parameters are available to use&lt;/STRONG&gt;:&lt;BR&gt;&lt;FONT color=#ff0000&gt;oAsset&lt;/FONT&gt; - The&amp;nbsp;generic asset&amp;nbsp;business object.&amp;nbsp;&amp;nbsp;&lt;BR&gt;&lt;FONT color=#ff0000&gt;curve&lt;/FONT&gt; - The name of the selected deterioration curve should be set to this&amp;nbsp;System.String parameter.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&lt;STRONG&gt;Below is a sample formula that will set the curve to &quot;Rapid&quot; or &quot;Slow&quot; depending on the Unit Type of the asset.&lt;/STRONG&gt;&lt;/P&gt;&#xA;&#xD;&lt;P&gt;Dim res As Hansen.Core.Result&lt;/P&gt;&#xA;&#xD;&lt;P&gt;If oAsset.UnitType = &quot;MADA&quot; Then&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp; curve = &quot;Rapid&quot;&lt;BR&gt;Else&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp; curve = &quot;Slow&quot;&lt;BR&gt;End If&lt;/P&gt;"/>
			<record name="AssetManagement.AssetAnalysisXDecisionModelNodeXDecisionNodeFormula"
			        EVENTKEY="2285"
			        PRODFAMILYNAME="AssetManagement.AssetAnalysis"
			        BUSOBJNAME="DecisionModelNode"
			        PAGENAME=""
			        NAME="DecisionNodeFormula"
			        NAMESPACE="AssetManagement.AssetAnalysis"
			        METHODPREFIX="DM"
			        METHODSIGNATURE="out System.Boolean bDecisionFormulaResult, Hansen.AssetManagement.AssetAnalysis.INeedsAnalysisSegment oAssetSegment"
			        DEFAULTDLLNAME="AssetAnalysis"
			        DEFAULTCOMMENT="&lt;P&gt;Formula for the Decision Model - Decision Node.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;If true is the result, the decision model tree advances to the node to the right of the current decision node.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;If false is the result, the decision model tree advances to the node below the current decision node.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;Output is &lt;STRONG&gt;bDecisionFormulaResult &lt;/STRONG&gt;as datatype Boolean (true/false). (eg. bDecisionFormulaResult = true).&lt;/P&gt;&#xA;&#xD;&lt;P&gt;The following example return true if the latest deteriorated value for the Index &quot;DICI&quot; is greater than 6. &lt;/P&gt;&#xA;&#xD;&lt;P&gt;Dim dValue as double &lt;BR&gt;dValue = oAssetSegment.GetLastestIndexDeterioratedValue (&quot;DICI&quot;)&lt;BR&gt;If dValue &amp;gt; 6 &lt;BR&gt;bDecisionFormulaResult = true&lt;BR&gt;Else&lt;BR&gt;bDecisionFormulaResult = false&lt;BR&gt;end if&lt;/P&gt;"/>
			<record name="AssetManagementXAssetInspectionIndexXSTSBIndexCalc"
			        EVENTKEY="2000"
			        PRODFAMILYNAME="AssetManagement"
			        BUSOBJNAME="AssetInspectionIndex"
			        PAGENAME=""
			        NAME="STSBIndexCalc"
			        NAMESPACE="AssetManagement"
			        METHODPREFIX="STSBCI"
			        METHODSIGNATURE="out System.Double IndexRating, System.String InspType, System.Int32 InspKey, Hansen.AssetManagement.Storm.IStormStorageBasin oAsset"
			        DEFAULTDLLNAME="AssetManagement"
			        DEFAULTCOMMENT="&lt;P&gt;This formula is used&amp;nbsp; to calculate an index for an asset inspection.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&lt;STRONG&gt;The following parameters are available to use&lt;/STRONG&gt;:&lt;BR&gt;&lt;FONT color=#ff0000&gt;InspKey&lt;/FONT&gt; - The inspection key of the inspection for which the index is calculated.&lt;BR&gt;&lt;FONT color=#ff0000&gt;oAsset&lt;/FONT&gt; - The water hydrant business object.&amp;nbsp; A list of inspections for this asset can be found at oAsset.ServiceInspections&lt;BR&gt;&lt;FONT color=#ff0000&gt;IndexRating&lt;/FONT&gt; - The calculated index should be assigned to this System.Double parameter.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&lt;STRONG&gt;Below is a sample formula that will find the current inspection and set the IndexRating value to the value of&amp;nbsp;the &quot;Flow&quot;&lt;/STRONG&gt;&amp;nbsp;&lt;STRONG&gt;property on the &quot;AgencyID.Inspections.Flow&quot; agency business object.&lt;/STRONG&gt;&lt;/P&gt;&#xA;&#xD;&lt;P&gt;Dim res As Hansen.Core.Result&lt;BR&gt;Dim oInsp As Hansen.AssetManagement.Storm.ISTSBServiceInspection&lt;/P&gt;&#xA;&#xD;&lt;P&gt;For Each oInsp In oAsset.ServiceInspections&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; If InspKey = oInsp.PrimaryKey Then&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; Dim oFlow as AgencyID.Inspections.Flow&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; oFlow = AgencyID.Inspections.Flow.GetInstanceFromParent&amp;nbsp;(oInsp,res)&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; IndexRating = oFlow.Flow&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; Exit For&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; End If&lt;BR&gt;Next&lt;/P&gt;"/>
			<record name="AssetManagementXAssetInspectionIndexXSTVIndexCalc"
			        EVENTKEY="2001"
			        PRODFAMILYNAME="AssetManagement"
			        BUSOBJNAME="AssetInspectionIndex"
			        PAGENAME=""
			        NAME="STVIndexCalc"
			        NAMESPACE="AssetManagement"
			        METHODPREFIX="STVCI"
			        METHODSIGNATURE="out System.Double IndexRating, System.String InspType, System.Int32 InspKey, Hansen.AssetManagement.Storm.IStormValve oAsset"
			        DEFAULTDLLNAME="AssetManagement"
			        DEFAULTCOMMENT="&lt;P&gt;This formula is used&amp;nbsp; to calculate an index for an asset inspection.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&lt;STRONG&gt;The following parameters are available to use&lt;/STRONG&gt;:&lt;BR&gt;&lt;FONT color=#ff0000&gt;InspKey&lt;/FONT&gt; - The inspection key of the inspection for which the index is calculated.&lt;BR&gt;&lt;FONT color=#ff0000&gt;oAsset&lt;/FONT&gt; - The water hydrant business object.&amp;nbsp; A list of inspections for this asset can be found at oAsset.ServiceInspections&lt;BR&gt;&lt;FONT color=#ff0000&gt;IndexRating&lt;/FONT&gt; - The calculated index should be assigned to this System.Double parameter.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&lt;STRONG&gt;Below is a sample formula that will find the current inspection and set the IndexRating value to the value of&amp;nbsp;the &quot;Flow&quot;&lt;/STRONG&gt;&amp;nbsp;&lt;STRONG&gt;property on the &quot;AgencyID.Inspections.Flow&quot; agency business object.&lt;/STRONG&gt;&lt;/P&gt;&#xA;&#xD;&lt;P&gt;Dim res As Hansen.Core.Result&lt;BR&gt;Dim oInsp As Hansen.AssetManagement.Storm.ISTVServiceInspection&lt;/P&gt;&#xA;&#xD;&lt;P&gt;For Each oInsp In oAsset.ServiceInspections&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; If InspKey = oInsp.PrimaryKey Then&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; Dim oFlow as AgencyID.Inspections.Flow&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; oFlow = AgencyID.Inspections.Flow.GetInstanceFromParent&amp;nbsp;(oInsp,res)&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; IndexRating = oFlow.Flow&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; Exit For&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; End If&lt;BR&gt;Next&lt;/P&gt;"/>
