			        CATEGORY="1014"
			        CODE="'Sample on how to call JournalSummaryCollection generate and load, then export the collection to ION&#xD;&#xA;&#xD;&#xA;Dim res As Result = Result.Success &#xD;&#xA;Dim fromDateTime as Nullable(of DateTime) = [enter date here] &#xD;&#xA;Dim toDateTime as Nullable(of DateTime) = DateTime.Now &#xD;&#xA;Dim journalSummaries as Hansen.Resources.IJournalSummaryCollection = ServerApplication.NewComponent(of Hansen.Resources.IJournalSummaryCollection) &#xD;&#xA;&#xD;&#xA;res = journalSummaries.GenerateAndLoadJournalSummary(fromDateTime, toDateTime)&#xD;&#xA;&#xD;&#xA;If res.IsSuccess = True then&#xD;&#xA;    res += Hansen.Core.Messaging.MessagingService.Send( journalSummaries,  Hansen.Core.Messaging.MessageTrigger.Added ) &#xD;&#xA;End if &#xD;&#xA;&#xD;&#xA;return res"/>
			<record name="1045"
			        SNIPPETKEY="1045"
			        NAME="ION Exp CDR Journal Run"
			        DESCRIPTION="Sample on how to create journal entries for CDR fee transactions"
			        CATEGORY="1009"
			        CODE="'Sample on how to create journal entries for CDR fee transactions&#xD;&#xA;Dim res As Result = Result.Success &#xD;&#xA;&#xD;&#xA;dim debit as string = &quot;&quot;&#xD;&#xA;dim credit as string = &quot;&quot;&#xD;&#xA;Dim updatedTranNo As IList(Of integer) = New List(Of Integer)&#xD;&#xA;&#xD;&#xA;dim feeTrans as Hansen.CDR.IFeeTransactionCollection = ServerApplication.NewComponent(of Hansen.CDR.IFeeTransactionCollection)&#xD;&#xA;dim where as DBOperativeCollection = new DBOperativeCollection()&#xD;&#xA;where.Add( new IDOperativeByCommonID( &quot;CDR&quot;, &quot;FeeTransaction.NeedsJournal&quot;, ComparisonOperator.DBNotNull, Nothing ) )&#xD;&#xA;res = feeTrans.Load(where, true)&#xD;&#xA;if res.IsSuccess Then&#xD;&#xA;For Each feeTran As Hansen.CDR.IFeeTransaction In feeTrans&#xD;&#xA;    if res.IsSuccess Then&#xD;&#xA;      ' this section shows examples on how to assign budget number based on fee type budget number&#xD;&#xA;       'credit = feeTran.Fee.FeeTypeVersion.FeeType.DestinationBudgetNumber&#xD;&#xA;       'debit = feeTran.Fee.FeeTypeVersion.FeeType.SourceBudgetNumber&#xD;&#xA;&#xD;&#xA;      ' this section shows examples on how to assign budget number based on fee transaction type&#xD;&#xA;      Select Case feeTran.TransactionType &#xD;&#xA;        Case &quot;FCHG&quot;&#xD;&#xA;             ' set credit/debt budget number here.&#xD;&#xA;             credit = &quot;[BudgetNumber]&quot;&#xD;&#xA;             debit = &quot;[BudgetNumber]&quot;&#xD;&#xA;        Case &quot;FADJ&quot;&#xD;&#xA;             ' set credit/debt budget number here.&#xD;&#xA;             credit = &quot;[BudgetNumber]&quot;&#xD;&#xA;             debit = &quot;[BudgetNumber]&quot;&#xD;&#xA;        Case &quot;FPAY&quot;&#xD;&#xA;             ' set credit/debt budget number here.&#xD;&#xA;             credit = &quot;[BudgetNumber]&quot;&#xD;&#xA;             debit = &quot;[BudgetNumber]&quot;&#xD;&#xA;        Case &quot;FREF&quot;&#xD;&#xA;             ' set credit/debt budget number here.&#xD;&#xA;             credit = &quot;[BudgetNumber]&quot;&#xD;&#xA;             debit = &quot;[BudgetNumber]&quot;&#xD;&#xA;        Case &quot;OVER&quot;&#xD;&#xA;             ' set credit/debt budget number here.&#xD;&#xA;             credit = &quot;[BudgetNumber]&quot;&#xD;&#xA;             debit = &quot;[BudgetNumber]&quot;&#xD;&#xA;        Case &quot;OXFR&quot;&#xD;&#xA;             ' set credit/debt budget number here.&#xD;&#xA;             credit = &quot;[BudgetNumber]&quot;&#xD;&#xA;             debit = &quot;[BudgetNumber]&quot;&#xD;&#xA;        Case &quot;OPAY&quot;&#xD;&#xA;             ' set credit/debt budget number here.&#xD;&#xA;             credit = &quot;[BudgetNumber]&quot;&#xD;&#xA;             debit = &quot;[BudgetNumber]&quot;&#xD;&#xA;        Case &quot;OREF&quot;&#xD;&#xA;             ' set credit/debt budget number here.&#xD;&#xA;             credit = &quot;[BudgetNumber]&quot;&#xD;&#xA;             debit = &quot;[BudgetNumber]&quot;&#xD;&#xA;        Case &quot;DEP&quot;&#xD;&#xA;             ' set credit/debt budget number here.&#xD;&#xA;             credit = &quot;[BudgetNumber]&quot;&#xD;&#xA;             debit = &quot;[BudgetNumber]&quot;&#xD;&#xA;        Case &quot;DADJ&quot;&#xD;&#xA;             ' set credit/debt budget number here.&#xD;&#xA;             credit = &quot;[BudgetNumber]&quot;&#xD;&#xA;             debit = &quot;[BudgetNumber]&quot;&#xD;&#xA;        Case &quot;DPAY&quot;&#xD;&#xA;             ' set credit/debt budget number here.&#xD;&#xA;             credit = &quot;[BudgetNumber]&quot;&#xD;&#xA;             debit = &quot;[BudgetNumber]&quot;&#xD;&#xA;        Case &quot;DREF&quot;&#xD;&#xA;             ' set credit/debt budget number here.&#xD;&#xA;             credit = &quot;[BudgetNumber]&quot;&#xD;&#xA;             debit = &quot;[BudgetNumber]&quot;&#xD;&#xA;        Case &quot;DRFO&quot;&#xD;&#xA;             ' set credit/debt budget number here.&#xD;&#xA;             credit = &quot;[BudgetNumber]&quot;&#xD;&#xA;             debit = &quot;[BudgetNumber]&quot;&#xD;&#xA;        Case Else &#xD;&#xA;               res =  new Result(-1, ResultSeverity.UserError , &quot;Credit/Debit need to be set &quot; )&#xD;&#xA;               Exit Select &#xD;&#xA;      End Select &#xD;&#xA;      if res.IsSuccess Then&#xD;&#xA;            dim journal as Hansen.Resources.IJournal = ServerApplication.NewComponent( of Hansen.Resources.IJournal)&#xD;&#xA;             journal.AccountingPeriod = 4   ' need to calculate accounting period based on transcation date time&#xD;&#xA;             journal.FiscalYear = feeTran.TransactionDateTime.Year   ' need to calculate fiscal year based on trnasaction date time&#xD;&#xA;             journal.Origin = Hansen.Resources.JournalOrigin.FeeTransaction&#xD;&#xA;             journal.CreditBudgetNumber.Code = credit&#xD;&#xA;             journal.DebitBudgetNumber.Code = debit&#xD;&#xA;             journal.TransactionBy = feeTran.TransactedBy.EmployeeId&#xD;&#xA;             journal.TransactionDateTime = feeTran.TransactionDateTime&#xD;&#xA;             journal.TransactionNumber = feeTran.TransactionNumber&#xD;&#xA;             journal.Amount = feeTran.Amount&#xD;&#xA;             res = journal.Add()&#xD;&#xA;             updatedTranNo.Add(journal.TransactionNumber)&#xD;&#xA;      End If&#xD;&#xA;    Else&#xD;&#xA;        Exit For&#xD;&#xA;    End If&#xD;&#xA;Next&#xD;&#xA;End IF&#xD;&#xA;&#xD;&#xA;Const sqlText As String = &quot;UPDATE CDR.APTRN SET NEEDSJOURNAL=NULL WHERE APTRNNO = @p&quot;&#xD;&#xA;'now update aptran to reflect the journal creation&#xD;&#xA;If res.IsSuccess Then&#xD;&#xA;    For Each key As Integer In updatedTranNo&#xD;&#xA;       If res.IsSuccess Then&#xD;&#xA;            Dim param As New DBParameter(&quot;@p&quot;, key.ToString())&#xD;&#xA;            Dim parameters As New DBParameterCollection()&#xD;&#xA;            parameters.Add(param)&#xD;&#xA;            res += DataServices.ExecSQLNonSelect(feeTrans.UserInfo.GetProvider(), sqlText, parameters)&#xD;&#xA;       Else&#xD;&#xA;            Exit For&#xD;&#xA;       End If&#xD;&#xA;   Next&#xD;&#xA;End If&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;return res"/>
