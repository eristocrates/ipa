			        BUSOBJNAME="DelinquencyScheme"
			        PAGENAME=""
			        NAME="EntryMilestoneFormula"
			        NAMESPACE="Billing"
			        METHODPREFIX="EMF"
			        METHODSIGNATURE="&#xA;&#xD;out System.String sMilestone, Hansen.Billing.IAccount oAccount, Hansen.Billing.IBillType oBillType, Hansen.Billing.IBill oBill"
			        DEFAULTDLLNAME="Billing"
			        DEFAULTCOMMENT="&lt;p&gt; Formula that returns the Delinquency Milestone to initially enter account or bill &lt;/p&gt;&#xD;&#xA;&#xD;&#xA;This method makes available the &lt;i&gt;Account&lt;/i&gt; object, named &lt;b&gt;oAccount&lt;/b&gt;, the &lt;i&gt;Bill Type&lt;/i&gt; object, named &lt;b&gt;oBillType&lt;/b&gt;, and the &lt;i&gt;Bill&lt;/i&gt; object, named  &lt;b&gt; oBill&lt;/b&gt; which can be used in your calculation to set a &lt;i&gt;System.String&lt;/i&gt; object named &lt;b&gt;sMilestone&lt;/b&gt;.&lt;br&gt;&lt;br&gt;For example, if the Account's Account Group Code  is &quot;REPT&quot; you can assign the &lt;b&gt; sMilestone&lt;/b&gt; as &quot;Hanger&quot;:&lt;br&gt;&lt;br&gt;&#xD;&#xA;If oAccount.AccountGroup.Code = &quot;REPT&quot; Then&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;sMilestone = &quot;Hanger&quot;&lt;br&gt;Else&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;sMilestone = &quot;Initial&quot;&lt;br&gt;End If&lt;br&gt;&lt;br&gt;&#xD;&#xA;&#xD;&#xA;If the &lt;i&gt;Account's&lt;/i&gt; &lt;i&gt;Account Delinquency&lt;/i&gt; is part of a &lt;i&gt;Bill Type&lt;/i&gt; that is set to Delinquency Per Bill then the  &lt;b&gt; oBill&lt;/b&gt; parameter will be present with a key greater than 1.  The &lt;b&gt;oBillType&lt;/b&gt; parameter should always have a key greater than one.  For example:&lt;br&gt;&lt;br&gt;&#xD;&#xA;&#xD;&#xA;If oBill.BillKey &gt; 1 and oBill.BillAmount &gt; 100 Then&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;sMilestone = &quot;Secondary&quot;&lt;br&gt;Else&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;sMilestone = &quot;Initial&quot;&lt;br&gt;End If&lt;br&gt;&lt;br&gt;"/>
			<record name="ResourcesXContactXCallCentrePopulateFromAddress"
			        EVENTKEY="2252"
			        PRODFAMILYNAME="Resources"
			        BUSOBJNAME="Contact"
			        PAGENAME=""
			        NAME="CallCentrePopulateFromAddress"
			        NAMESPACE="Resources"
			        METHODPREFIX="CCPFA"
			        METHODSIGNATURE="System.Collections.ArrayList colContacts, Hansen.Property.IAddress oAddress"
			        DEFAULTDLLNAME="CallCentrePopulateFromAddress"
			        DEFAULTCOMMENT="&lt;P&gt;' This formula is called from the &quot;Populate from Address&quot; button in CallCentre.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;' Usually the caller will be calling about there own residence, so it makes sense to provide a button that determines the Contact related to this address.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;' Eg&lt;/P&gt;&#xA;&#xD;&lt;P&gt;'Variables&lt;BR&gt;Dim theRes As Result = Result.Success&lt;/P&gt;&#xA;&#xD;&lt;P&gt;Dim myContacts As new ArrayList&lt;/P&gt;&#xA;&#xD;&lt;P&gt;'Create link collection&lt;BR&gt;dim oLinks as IAddressContactLinkCollection=ServerApplication.NewComponent(&quot;Hansen.Property.AddressContactLinkCollection&quot;,oAddress.UserInfo)&lt;/P&gt;&#xA;&#xD;&lt;P&gt;'Where clause for tenants ------------------------------------&lt;BR&gt;Dim oWhere As New DBOperativeCollection&lt;/P&gt;&#xA;&#xD;&lt;P&gt;oWhere.Add(New IDOperativeByCommonID(&quot;Property&quot;, &quot;AddressContactLink.Address&quot;, ComparisonOperator.Equal, oAddress.AddressKey))&lt;/P&gt;&#xA;&#xD;&lt;P&gt;oWhere.Add(New IDOperativeByCommonID(&quot;Property&quot;, &quot;AddressContactLink.IsOwner&quot;, ComparisonOperator.Equal, &quot;N&quot;))&lt;/P&gt;&#xA;&#xD;&lt;P&gt;oWhere.Add(New IDOperativeByCommonID(&quot;Property&quot;, &quot;AddressContactLink.IsOccupant&quot;, ComparisonOperator.Equal, &quot;Y&quot;))&lt;BR&gt;&lt;/P&gt;&#xA;&#xD;&lt;P&gt;'Load tenant links&lt;BR&gt;theRes = CType(oLinks, IComponent).Load(oWhere)&lt;/P&gt;&#xA;&#xD;&lt;P&gt;if oLinks.Count&amp;lt;1 then&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&amp;nbsp; 'Where clause for owners ------------------------------------&lt;BR&gt;&amp;nbsp; oWhere = New DBOperativeCollection&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&amp;nbsp; oWhere.Add(New IDOperativeByCommonID(&quot;Property&quot;, &quot;AddressContactLink.Address&quot;, ComparisonOperator.Equal, oAddress.AddressKey))&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&amp;nbsp; oWhere.Add(New IDOperativeByCommonID(&quot;Property&quot;, &quot;AddressContactLink.IsOwner&quot;, ComparisonOperator.Equal, &quot;Y&quot;))&lt;BR&gt;&amp;nbsp; &lt;/P&gt;&#xA;&#xD;&lt;P&gt;&amp;nbsp; 'Load owner links&lt;BR&gt;&amp;nbsp; theRes = CType(oLinks, IComponent).Load(oWhere)&lt;/P&gt;&#xA;&#xD;&lt;P&gt;end if&lt;/P&gt;&#xA;&#xD;&lt;P&gt;if oLinks.Count&amp;lt;1 then&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&amp;nbsp; 'Where clause for everyone ------------------------------------&lt;BR&gt;&amp;nbsp; oWhere = New DBOperativeCollection&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&amp;nbsp; oWhere.Add(New IDOperativeByCommonID(&quot;Property&quot;, &quot;AddressContactLink.Address&quot;, ComparisonOperator.Equal, oAddress.AddressKey))&lt;BR&gt;&amp;nbsp;&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&amp;nbsp; 'Load everyone links&lt;BR&gt;&amp;nbsp; theRes = CType(oLinks, IComponent).Load(oWhere)&lt;/P&gt;&#xA;&#xD;&lt;P&gt;end if&lt;/P&gt;&#xA;&#xD;&lt;P&gt;'Add all the returned contacts to return arraylist&lt;BR&gt;dim oLink as IAddressContactLink&lt;/P&gt;&#xA;&#xD;&lt;P&gt;for each oLink in oLinks&lt;BR&gt;&amp;nbsp; myContacts.Add(oLink.Contact)&lt;BR&gt;next&lt;/P&gt;&#xA;&#xD;&lt;P&gt;Dim data As New DataSet&lt;BR&gt;Dim dt As DataTable = data.Tables.Add()&lt;BR&gt;dt.Columns.Add(&quot;ContactKey&quot;, System.Type.GetType(&quot;System.Int32&quot;))&lt;BR&gt;dt.Columns.Add(&quot;LastName&quot;, System.Type.GetType(&quot;System.String&quot;))&lt;BR&gt;dt.Columns.Add(&quot;FirstName&quot;, System.Type.GetType(&quot;System.String&quot;))&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;BR&gt;dt.Columns.Add(&quot;Address&quot;, System.Type.GetType(&quot;System.String&quot;))&lt;BR&gt;dt.Columns.Add(&quot;City&quot;, System.Type.GetType(&quot;System.String&quot;))&lt;BR&gt;dt.Columns.Add(&quot;State&quot;, System.Type.GetType(&quot;System.String&quot;))&lt;BR&gt;dt.Columns.Add(&quot;PostalCode&quot;, System.Type.GetType(&quot;System.String&quot;))&lt;BR&gt;dt.Columns.Add(&quot;DayPhone&quot;, System.Type.GetType(&quot;System.String&quot;))&lt;/P&gt;&#xA;&#xD;&lt;P&gt;Dim i As Integer &lt;BR&gt;Dim oContact As IContact&lt;/P&gt;&#xA;&#xD;&lt;P&gt;for i=0 To myContacts.Count-1&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; oContact = CType(myContacts(i), IContact)&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; Dim idKey As Integer = oContact.Identity.IdentityKey&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; Dim myIdentity As IContactIdentity = ServerApplication.NewComponent(&quot;Hansen.Resources.ContactIdentity&quot;, oAddress.UserInfo)&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; myIdentity.IdentityKey = idKey&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; myIdentity.LoadByKey()&lt;BR&gt;&amp;nbsp;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; Dim dr As DataRow = dt.NewRow()&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; dr(&quot;ContactKey&quot;) = oContact.ContactKey&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; dr(&quot;LastName&quot;) = myIdentity.LastName&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; dr(&quot;FirstName&quot;) = myIdentity.FirstName&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; dr(&quot;Address&quot;) = oContact.AddressLine1&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; dr(&quot;City&quot;) = oContact.City&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; dr(&quot;PostalCode&quot;) = oContact.PostalCode&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; dr(&quot;DayPhone&quot;) = oContact.DayPhone&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; dt.Rows.Add(dr)&lt;/P&gt;&#xA;&#xD;&lt;P&gt;next&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;/P&gt;&#xA;&#xD;&lt;P&gt;colContacts.Add(data)&amp;nbsp;&amp;nbsp; &lt;/P&gt;&#xA;&#xD;&lt;P&gt;return theRes&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&amp;nbsp;&lt;/P&gt;"/>
			<record name="CRMXServiceRequestXCallCentreBeforeSave"
			        EVENTKEY="2253"
			        PRODFAMILYNAME="CRM"
			        BUSOBJNAME="ServiceRequest"
			        PAGENAME=""
			        NAME="CallCentreBeforeSave"
			        NAMESPACE="CRM"
			        METHODPREFIX="CCBS"
			        METHODSIGNATURE="Hansen.CRM.IServiceRequest oServiceRequest, Hansen.CRM.ICustomerCall oPrimaryCall, System.String FullPath"
			        DEFAULTDLLNAME="CallCentreBeforeSave"
			        DEFAULTCOMMENT="&lt;P&gt;' This is fired before a request is saved. &lt;/P&gt;&#xA;&#xD;&lt;P&gt;'Eg. One customer used it to enforce Contact Phone and Mobile Number and also inserted the script path (to the request type) into the Customer Call Comments.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;Dim res As Hansen.Core.Result = Result.Success&lt;/P&gt;&#xA;&#xD;&lt;P&gt;Dim oContact As Hansen.Resources.IContact&lt;/P&gt;&#xA;&#xD;&lt;P&gt;Dim phone, mobile As String&lt;/P&gt;&#xA;&#xD;&lt;P&gt;oContact = oPrimaryCall.Contact&lt;/P&gt;&#xA;&#xD;&lt;P&gt;phone = oContact.DayPhone.Trim()&lt;BR&gt;mobile = oContact.MobileNumber.Trim()&lt;BR&gt;&lt;/P&gt;&#xA;&#xD;&lt;P&gt;' To enforce the user to enter Contact Phone otherwise throw an exception&lt;BR&gt;If phone = &quot;&quot; And (oServiceRequest.ServiceRequestNumber = 0 Or oServiceRequest.ServiceRequestNumber = 1) Then&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; res = new Result(0, ResultSeverity.UserError, &quot;You must enter Contact Phone&quot;)&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;BR&gt;Else&amp;nbsp;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp; ' To enforce the user to enter Contact Mobile otherwise throw an exception&lt;BR&gt;&amp;nbsp;&amp;nbsp; If mobile = &quot;&quot; And (oServiceRequest.ServiceRequestNumber = 0 Or oServiceRequest.ServiceRequestNumber = 1) Then&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; res = new Result(0, ResultSeverity.UserError, &quot;You must enter Contact Mobile&amp;nbsp; Number&quot;)&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;BR&gt;End If&lt;BR&gt;End If&lt;BR&gt;&lt;/P&gt;"/>
			<record name="CDR.CodeEnforcementXCaseXReviewAssignmentGroup"
			        EVENTKEY="2254"
			        PRODFAMILYNAME="CDR.CodeEnforcement"
			        BUSOBJNAME="Case"
			        PAGENAME=""
			        NAME="ReviewAssignmentGroup"
			        NAMESPACE="CDR.CodeEnforcement"
			        METHODPREFIX="RAG"
			        METHODSIGNATURE="out System.String AssignmentGroup, Hansen.CDR.CodeEnforcement.ICase oCase"
			        DEFAULTDLLNAME="CDRCodeEnforcement"
			        DEFAULTCOMMENT="This event decides the assignment group that should be used when a reviewer is assigned.&lt;BR&gt;&lt;BR&gt;Example:&lt;BR&gt;&lt;BR&gt;AssignmentGroup = &quot;Group A&quot;"/>
			<record name="CRMXServiceRequestXCallCentreWaterOffSearch"
			        EVENTKEY="2255"
			        PRODFAMILYNAME="CRM"
			        BUSOBJNAME="ServiceRequest"
			        PAGENAME=""
			        NAME="CallCentreWaterOffSearch"
			        NAMESPACE="CRM"
			        METHODPREFIX="CCWO"
			        METHODSIGNATURE="Hansen.CRM.IServiceRequest oServiceRequest, Hansen.Property.IAddress oAddress, System.Double searchRadius, System.Object myObject"
			        DEFAULTDLLNAME="CallCentreSearch"
			        DEFAULTCOMMENT="&lt;p&gt;' This formula is used to return a DataSet containing Service Requests (and WorkOrders) to be displayed in the WaterOff grid control in CallCentre. It is very flexible in that you create the dataset using standard SQL and the data is displayed in the WaterOff grid control where the column names match the grid columns id's (case sensitive). Use the content manager to change the WaterOff grid control (rename column id's, add new columns, etc.) if required.&lt;/p&gt;&#xD;&#xA;&lt;p&gt;'NOTE: This formula should not be changed as part of any implementation.  Rather, it should be copied to another client specific formula.  The formula will be replaced on upgrades to new versions of the Hansen8 software&lt;/p&gt; &#xD;&#xA;&lt;p&gt;' Passed to the formula is the current Service Request object, Address object, and the search Radius.&lt;/p&gt;   &#xD;&#xA;&lt;p&gt;' Cast the parameter, myObject of System.Object to System.Data.DataSet, create a DataTable from the SQL query, and then add this to the dataset.&lt;/p&gt;  &#xD;&#xA;&lt;p&gt;'EG.  &#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;p&gt;' To make this Formula work in MT the SQL query is refactored to use the DBOperativeCollection methods since DataServices is not allowed currently in the Whitelist, it will still return the DataSet 11/10/2022&lt;/p&gt;&#xD;&#xA;dim doRadiusSearch as boolean = False&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;Dim res As Hansen.Core.Result = Result.Success  &#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;Try  &#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;p&gt;' Check if we do a radius search&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;if not oAddress is Nothing then&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;if oAddress.GPSXCoordinate &lt;&gt; 1 and oAddress.GPSYCoordinate &lt;&gt; 1 then&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;doRadiusSearch = True&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;end if&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;end if  &#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;p&gt;' Cast myObject to DataSet&lt;/p&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;Dim myDataSet As System.Data.DataSet = CType(myObject, System.Data.DataSet)  &#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;if doRadiusSearch then  &#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dim dSet As new System.Data.DataSet&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Dim oServiceRequestCollection As Hansen.CRM.IServiceRequestCollection = ServerApplication.NewComponent(Of Hansen.CRM.IServiceRequestCollection)()&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Dim oSelect as DBOperativeCollection = New DBOperativeCollection&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;oSelect.DefineJoin(Of IServiceRequest, IAddress)(JoinType.Inner, Function(x) x.Address.AddressKey, Function(x) x.AddressKey)&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;oSelect.DefineJoin(Of IServiceRequest, IServiceRequestType)(JoinType.Inner, Function(x) x.RequestType.RequestTypeKey, Function(x) x.RequestTypeKey)&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;oSelect.Add(new IDOperativeByCommonID(&quot;CRM&quot;, &quot;ServiceRequest&quot;))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Dim oWhere As DBOperativeCollection  = New DBOperativeCollection&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;oWhere.Add(New IDOperativeByCommonID(&quot;CRM&quot;, &quot;ServiceRequest.IsResolved&quot;, ComparisonOperator.Equal, &quot;N&quot;))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;oWhere.Add(New IDOperativeByCommonID(&quot;CRM&quot;, &quot;ServiceRequestType.RequestType&quot;, ComparisonOperator.Equal, &quot;WATEROFF&quot;))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;oWhere.Add(New IDOperativeByCommonID(&quot;PROPERTY&quot;, &quot;Address.GPSXCoordinate&quot;, ComparisonOperator.GreaterThan, oAddress.GPSXCoordinate - searchRadius))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;oWhere.Add(New IDOperativeByCommonID(&quot;PROPERTY&quot;, &quot;Address.GPSXCoordinate&quot;, ComparisonOperator.LessThan, oAddress.GPSXCoordinate + searchRadius))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;oWhere.Add(New IDOperativeByCommonID(&quot;PROPERTY&quot;, &quot;Address.GPSYCoordinate&quot;, ComparisonOperator.GreaterThan, oAddress.GPSYCoordinate - searchRadius))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;oWhere.Add(New IDOperativeByCommonID(&quot;PROPERTY&quot;, &quot;Address.GPSYCoordinate&quot;, ComparisonOperator.LessThan, oAddress.GPSYCoordinate + searchRadius))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;oServiceRequestCollection.MaxRecords = 100000&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;res = oServiceRequestCollection.Load(oSelect, oWhere, Nothing, true, true)&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;p&gt;' Create data table&lt;/p&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Dim dt As  System.Data.DataTable = dSet.Tables.Add()&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;p&gt;' Add the grid columns&lt;/p&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dt.Columns.Add(&quot;SRNumber&quot;, System.Type.GetType(&quot;System.Int32&quot;))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dt.Columns.Add(&quot;colViewer&quot;, System.Type.GetType(&quot;System.Int32&quot;))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dt.Columns.Add(&quot;gcWorkOrderKey&quot;, System.Type.GetType(&quot;System.Int32&quot;))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dt.Columns.Add(&quot;Address&quot;, System.Type.GetType(&quot;System.String&quot;))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dt.Columns.Add(&quot;gcPriority&quot;, System.Type.GetType(&quot;System.String&quot;))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dt.Columns.Add(&quot;ProblemType&quot;, System.Type.GetType(&quot;System.String&quot;))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dt.Columns.Add(&quot;gcRequestTypeDesc&quot;, System.Type.GetType(&quot;System.String&quot;))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dt.Columns.Add(&quot;gcInitialDate&quot;, System.Type.GetType(&quot;System.DateTime&quot;))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dt.Columns.Add(&quot;gcDistance&quot;, System.Type.GetType(&quot;System.Double&quot;))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;If (res.IsSuccess And Not res.IsNoDataFound) Then&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;For Each oServiceRequestRetrieved In oServiceRequestCollection&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;p&gt;' Create datarow&lt;/p&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Dim dr As DataRow = dt.NewRow()&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dr(&quot;SRNumber&quot;) = oServiceRequestRetrieved.ServiceRequestNumber&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dr(&quot;colViewer&quot;) = oServiceRequestRetrieved.ServiceRequestNumber&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dr(&quot;gcWorkOrderKey&quot;) = 1&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dr(&quot;Address&quot;) = oServiceRequestRetrieved.Address.StreetNumber + &quot; &quot; + oServiceRequestRetrieved.Address.StreetName + &quot; &quot; + oServiceRequestRetrieved.Address.State + &quot; &quot; + oServiceRequestRetrieved.Address.ZIP&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dr(&quot;gcPriority&quot;) = oServiceRequestRetrieved.Priority.Code&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dr(&quot;ProblemType&quot;) = oServiceRequestRetrieved.RequestType.RequestType&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dr(&quot;gcRequestTypeDesc&quot;) = oServiceRequestRetrieved.RequestType.RequestDescription&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dr(&quot;gcInitialDate&quot;) = oServiceRequestRetrieved.InitiatedDateTime&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dr(&quot;gcDistance&quot;) = Math.Sqrt(((oAddress.GPSXCoordinate - oServiceRequestRetrieved.Address.GPSXCoordinate) ^ 2) + ((oAddress.GPSYCoordinate - oServiceRequestRetrieved.Address.GPSYCoordinate) ^ 2))&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dt.Rows.Add(dr)&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;If (Not res.IsSuccess) Then&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;res = New Result(0, ResultSeverity.UserError, res.Message)&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Return res&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;End If&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Next&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;myDataSet.Tables.Add(dSet.Tables(0).Copy())&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;End If&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&amp;nbsp;&amp;nbsp;&amp;nbsp;end if&#xD;&#xA;&lt;BR&gt;   &#xD;&#xA;Cat