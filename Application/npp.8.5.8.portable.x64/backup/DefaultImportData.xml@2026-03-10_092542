			        DEFAULTDLLNAME="CDRCodeEnforcement"
			        DEFAULTCOMMENT="&lt;P&gt;This method makes available the &lt;I&gt;Case&lt;/I&gt; object, named &lt;B&gt;oCase&lt;/B&gt;, which can be used in your calculation to set a &lt;I&gt;System.DateTime&lt;/I&gt; object named &lt;B&gt;ScheduledDate.&lt;/B&gt;&lt;/P&gt;&#xA;&#xD;&lt;P&gt;For example, the following formula indicates that the inspection scheduled date&amp;nbsp;is&amp;nbsp;14 days from today.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;ScheduledDate = System.DateTime.Now.AddDays(14)&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&amp;nbsp;&lt;/P&gt;"/>
			<record name="CDR.PlanningXPlanningConditionInheritanceRuleXCheckInheritancePROJ"
