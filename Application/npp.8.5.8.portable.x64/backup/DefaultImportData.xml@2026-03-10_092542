			        METHODSIGNATURE="out System.String payload, Hansen.Cashiering.IMerchantAccount oMerchantAccount, Hansen.Cashiering.IDrawerTransaction oDrawerTransaction,&#xD;&#xA;Hansen.Cashiering.IPaymentServerTransaction oPaymentServerTransaction, System.String requestPayload"
