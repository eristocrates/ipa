			<record name="Core.AttachmentsXAttachmentXDocumentUpdate"
			        EVENTKEY="2425"
			        PRODFAMILYNAME="Core.Attachments"
			        BUSOBJNAME="Attachment"
			        PAGENAME=""
			        NAME="DocumentUpdate"
			        NAMESPACE=""
			        METHODPREFIX=""
			        METHODSIGNATURE="out System.Boolean dummy, System.Object oBusinessObject, System.Object MetaData, Hansen.Core.DocumentManagement.Services.UpdateDocumentRequest oRequest"
			        DEFAULTDLLNAME=""
			        DEFAULTCOMMENT="&lt;P&gt;&lt;FONT face=&quot;Times New Roman&quot;&gt;This formula is used when a document is updated.&lt;/FONT&gt;&lt;/P&gt;&#xD;&#xA;&#xD;&#xA;&lt;P&gt;&lt;FONT face=&quot;Times New Roman&quot;&gt;&lt;STRONG&gt;The following parameters are available to use&lt;/STRONG&gt;:&lt;BR&gt;&#xD;&#xA;&lt;SPAN style=&quot;COLOR: red&quot;&gt;oBusinessObject &lt;/SPAN&gt;- System.Object type. Represents the business object associated with the updated document.&amp;nbsp;&amp;nbsp;&lt;BR&gt;&#xD;&#xA;&lt;SPAN style=&quot;COLOR: red&quot;&gt;MetaData&lt;/SPAN&gt;&amp;nbsp;- System.Object.&amp;nbsp; This object contains the metadata associated with the document. This is castable to Dictionary(&lt;SPAN style=&quot;COLOR: blue&quot;&gt;Of String&lt;/SPAN&gt;, &lt;SPAN style=&quot;COLOR: blue&quot;&gt;String&lt;/SPAN&gt;)&lt;BR&gt;&#xD;&#xA;&#xD;&#xA;&lt;/FONT&gt;&lt;/P&gt;&#xD;&#xA;&#xD;&#xA;&lt;BR&gt;Example:&lt;BR&gt;&lt;SPAN style=&quot;FONT-SIZE: 10pt; FONT-FAMILY: 'Courier New'&quot;&gt;&lt;BR /&gt;&#xD;&#xA;MetaData.Add(&lt;SPAN style=&quot;COLOR: purple&quot;&gt;&quot;Moniker&quot;&lt;/SPAN&gt;, oBusinessObject.MonikerName)&lt;BR /&gt;&#xD;&#xA;MetaData.Add(&lt;SPAN style=&quot;COLOR: purple&quot;&gt;&quot;PrimaryKey&quot;&lt;/SPAN&gt;, oBusinessObject.PrimaryKey)&lt;BR /&gt;&lt;BR /&gt;"/>
			<record name="CRMXServiceRequestXCustomValidatePortalInfo"
			        EVENTKEY="0"
			        PRODFAMILYNAME="CRM"
			        BUSOBJNAME="ServiceRequest"
			        PAGENAME=""
			        NAME="CustomValidatePortalInfo"
			        NAMESPACE="CRM"
			        METHODPREFIX="CVPI"
			        METHODSIGNATURE="Hansen.CRM.IServiceRequest oServiceRequest"
			        DEFAULTDLLNAME="CRM"
			        DEFAULTCOMMENT="&lt;p&gt;This event is defined to custom validate data entered by the user in the submit instrument portlet in portal.  This event is invoked when user leaves the Record Information tab to prevent them from going foward if invalid data is entered.&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;p&gt;All validation messages should be created as a Hansen.Core.Result with ResultSeverity equal to UserError.&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;p&gt;A validation message can be displayed on the control level by adding the portal control id to the properties list of the Result.  If a portal control is not added to the properties list, the validation message will display at the top of the page.&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;p&gt;The following example will create a control level validation message and a page level validation message&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;Dim res as Hansen.Core.Result = Result.Success&#xD;&#xA;&lt;BR&gt;if oServiceRequest.RequestType.RequestType = &quot;SFD&quot; Then&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;'Page level message&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;if oServiceRequest.Location.Length &lt; 10 Then&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Dim resOcc as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &quot;Location Description too short.&quot;)&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;res += resOcc&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;End if&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;'Control level message&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;if oServiceRequest.Location.Length &lt; 100 Then&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Dim resLoc as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &quot;Location Description must be greater than 100 characters.&quot;)&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;resLoc.properties.Add( &quot;validationError&quot;, &quot;locationDetails&quot; )&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;res += resLoc&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;End If&#xD;&#xA;&lt;BR&gt;End if&#xD;&#xA;&lt;BR&gt;return res"/>
			<record name="CRMXServiceRequestXCustomValidatePortalDetails"
			        EVENTKEY="0"
			        PRODFAMILYNAME="CRM"
			        BUSOBJNAME="ServiceRequest"
			        PAGENAME=""
			        NAME="CustomValidatePortalDetails"
			        NAMESPACE="CRM"
			        METHODPREFIX="CVPD"
			        METHODSIGNATURE="Hansen.CRM.IServiceRequest oServiceRequest"
			        DEFAULTDLLNAME="CRM"
			        DEFAULTCOMMENT="&lt;p&gt;This event is defined to custom validate data entered by the user in the submit instrument portlet in portal.  This event is invoked when user leaves the Additional Information tab to prevent them from going foward if invalid data is entered on detail pages.&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;p&gt;All validation messages should be created as a Hansen.Core.Result with ResultSeverity equal to UserError.&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;p&gt;A validation message can be displayed on the control level by adding the portal control id to the properties list of the Result.  If a portal control is not added to the properties list, the validation message will display at the top of the page.&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;p&gt;The following example will create a control level validation message and a page level validation message&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;Dim res as Hansen.Core.Result = Result.Success&#xD;&#xA;&lt;BR&gt;if oServiceRequest.RequestType.RequestType = &quot;SFD&quot; Then&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;InforClient.CRM.CustomDetails oCustomDetails = InforClient.CRM.CustomDetails.GetInstanceFromParent(oServiceRequest.RequestType.ServiceRequestType[0], ref res);&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt; &amp;nbsp;&amp;nbsp;&amp;nbsp;'Page level message&#xD;&#xA;&lt;BR&gt; &amp;nbsp;&amp;nbsp;&amp;nbsp;if oCustomDetails.IsApproved = false then&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Dim resApp as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &quot;You must check the box that you approve the terms of this request.&quot;)&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;res += resApp&#xD;&#xA;&lt;BR&gt; &amp;nbsp;&amp;nbsp;&amp;nbsp;End if&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;'Control level message&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;if oCustomDetails.CustomComments.Length &lt; 100 Then&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Dim resCom as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &quot;Details Comments must be greater than 100 characters.&quot;)&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;resCom.properties.Add( &quot;validationError&quot;, &quot;CustomComments&quot; )&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;res += resCom&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;End If&#xD;&#xA;&lt;BR&gt;End if&#xD;&#xA;&lt;BR&gt;return res"/>
			<record name="CRMXServiceRequestXCustomValidatePortalPublicContact"
			        EVENTKEY="0"
			        PRODFAMILYNAME="CRM"
			        BUSOBJNAME="ServiceRequest"
			        PAGENAME=""
			        NAME="CustomValidatePortalPublicContact"
			        NAMESPACE="CRM"
			        METHODPREFIX="CVPPC"
			        METHODSIGNATURE="Hansen.CRM.IServiceRequest oServiceRequest"
			        DEFAULTDLLNAME="CRM"
			        DEFAULTCOMMENT="&lt;p&gt;This event is defined to custom validate data entered by the user in the submit instrument portlet in portal.  This event is invoked when user leaves the Contact Information tab to prevent them from going foward if invalid data is entered.&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;p&gt;All validation messages should be created as a Hansen.Core.Result with ResultSeverity equal to UserError.&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;p&gt;A validation message can be displayed on the control level by adding the portal control id to the properties list of the Result.  If a portal control is not added to the properties list, the validation message will display at the top of the page.&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;p&gt;The following example will create a control level validation message and a page level validation message&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;Dim res as Hansen.Core.Result = Result.Success&#xD;&#xA;&lt;BR&gt;if oServiceRequest.RequestType.RequestType = &quot;SFD&quot; Then&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;'Page level message&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;if oServiceRequest.PrimaryCaller.Contact.State = &quot;AL&quot; And String.IsNullOrWhiteSpace(oServiceRequest.PrimaryCaller.Contact.EMailAddress) Then&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Dim resOcc as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &quot;E-mail address is required for this state.&quot;)&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;res += resOcc&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;End if&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;'Control level message&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;if oServiceRequest.PrimaryCaller.Contact.City.Length &lt; 3 Then&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Dim resLoc as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &quot;City is too short.&quot;)&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;resLoc.properties.Add( &quot;validationError&quot;, &quot;contact.city&quot; )&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;res += resLoc&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;End If&#xD;&#xA;&lt;BR&gt;End if&#xD;&#xA;&lt;BR&gt;return res"/>
			<record name="CRMXServiceRequestXCustomValidatePortalLocation"
			        EVENTKEY="0"
			        PRODFAMILYNAME="CRM"
			        BUSOBJNAME="ServiceRequest"
			        PAGENAME=""
			        NAME="CustomValidatePortalLocation"
			        NAMESPACE="CRM"
			        METHODPREFIX="CVPI"
			        METHODSIGNATURE="Hansen.CRM.IServiceRequest oServiceRequest"
			        DEFAULTDLLNAME="CRM"
			        DEFAULTCOMMENT="&lt;p&gt;This event is defined to custom validate data entered by the user in the submit instrument portlet in portal.  This event is invoked when user leaves the Location tab to prevent them from going foward if invalid data is entered.&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;p&gt;All validation messages should be created as a Hansen.Core.Result with ResultSeverity equal to UserError.&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;p&gt;A validation message can be displayed on the control level by adding the portal control id to the properties list of the Result.  If a portal control is not added to the properties list, the validation message will display at the top of the page.&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;p&gt;The following example will create a control level validation message and a page level validation message&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;Dim res as Hansen.Core.Result = Result.Success&#xD;&#xA;&lt;BR&gt;if oServiceRequest.RequestType.RequestType = &quot;SFD&quot; Then&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;'Page level message&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;if oServiceRequest.Location.Length &lt; 10 Then&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Dim resOcc as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &quot;Location Description too short.&quot;)&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;res += resOcc&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;End if&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;'Control level message&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;if oServiceRequest.Location.Length &lt; 100 Then&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Dim resLoc as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &quot;Location Description must be greater than 100 characters.&quot;)&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;resLoc.properties.Add( &quot;validationError&quot;, &quot;locationDetails&quot; )&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;res += resLoc&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;End If&#xD;&#xA;&lt;BR&gt;End if&#xD;&#xA;&lt;BR&gt;return res"/>
			<record name="MetadataXDatabaseProcessingXAfterSnapshotRefresh"
			        EVENTKEY="0"
			        PRODFAMILYNAME="Metadata"
			        BUSOBJNAME="DatabaseProcessing"
			        PAGENAME=""
			        NAME="AfterSnapshotRefresh"
			        NAMESPACE="Metadata"
			        METHODPREFIX="SSREF"
			        METHODSIGNATURE=""
			        DEFAULTDLLNAME="Metadata"
			        DEFAULTCOMMENT="&lt;p&gt;This event is called after a snapshot refresh operation has completed on the destination environment.  This option is only called for Multi-Tenant SaaS product offerings.&lt;/p&gt;"/>
			<record name="Core.AttachmentsXDocumentTypeXDocumentTypeRequirement"
			        EVENTKEY="0"
			        PRODFAMILYNAME="Core.Attachments"
			        BUSOBJNAME="DocumentType"
			        PAGENAME=""
			        NAME="DocumentTypeRequirement"
			        NAMESPACE="Core.Attachments"
			        METHODPREFIX="DTR"
			        METHODSIGNATURE="Hansen.Core.Attachments.IDocumentTypeRequirement DocumentTypeRequirement,  Hansen.Core.Business.IComponent Parent"
			        DEFAULTDLLNAME="Attachments"
			        DEFAULTCOMMENT="&lt;p&gt;This event is used to determine if the file requirements for a document type in association with a specific parent record have been met.&amp;nbsp; Default information will be sent in through the DocumentTypeRequirement parameter.&amp;nbsp; This can then be overridden.&amp;nbsp; The parent of the attachments will be available through the Parent parameter. When checking the file requirements for CDR applications, licenses, or cases, the parent may be a BuildingApplication, LicenseApplication, Case, PlanningApplication, ProjectApplication, TradeLicense, or UseApplication.&lt;/p&gt;&#xD;&#xA;&lt;p&gt;Information about the requirements is returned using either a Hansen.Core.Attachments.DocumentTypeRequirement object or a Hansen.Core.Attachments.PortalDocumentTypeRequirement object.&amp;nbsp; If run from Portal, a PortalDocumentTypeRequirement object will be passed in.&amp;nbsp; Otherwise, it will be a DocumentTypeRequirement object.&lt;/p&gt;&#xD;&#xA;&lt;p&gt;The following properties on the Hansen.Core.Attachments.DocumentTypeRequirement object are available:&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;em&gt;DocumentTypeName&lt;/em&gt;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;em&gt;&amp;nbsp; &amp;nbsp; The identifier of the document type.&amp;nbsp; Used to look up attachments associated with the parent record.&lt;/em&gt;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;em&gt;MinimumRequired&lt;/em&gt;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;Set to the minimum number of files needed to satisfy the requirement.&amp;nbsp; This will be set to 0 by default.&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;em&gt;Instructions&lt;/em&gt;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;Instructions to present to the user on how to satisfy the requirement. If no instruction text is entered, a default message will be shown.&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;br /&gt;When run from Portal, the following properties are available in the PortalDocumentTypeRequrement object in addition to the ones shown above:&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;em&gt;SkipPortalPendingTask&lt;/em&gt;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;If set to true, it will not be shown as a Pending Task in My Dashboard.&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;em&gt;IsVisibleToPublic&lt;/em&gt;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;If set to true, the requirement will be visible to the public.&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;br /&gt;&lt;em&gt;PortalInstructions&lt;/em&gt;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;Allows for different instructions to be shown based on the user type. If no instruction text is entered for a specific user type, the system will try to use the text from the Instructions property.&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;br /&gt;Example:&lt;/p&gt;&#xD;&#xA;&lt;p&gt;' Cast the attachment parent to a CDR BuildingApplication&lt;/p&gt;&#xD;&#xA;&lt;p&gt;if TypeOf Parent Is Hansen.CDR.Building.IBuildingApplication then&lt;/p&gt;&#xD;&#xA;&lt;p&gt;Dim cdrBuildingApplication as Hansen.CDR.Building.IBuildingApplication&lt;/p&gt;&#xD;&#xA;&lt;p&gt;cdrBuildingApplication = CType(Parent, Hansen.CDR.Building.IBuildingApplication)&lt;/p&gt;&#xD;&#xA;&lt;p&gt;if cdrBuildingApplication.ActualValuation &amp;lt; 100000 then&lt;/p&gt;&#xD;&#xA;&lt;p&gt;DocumentTypeRequirement.MinimumRequired = 1&lt;/p&gt;&#xD;&#xA;&lt;p&gt;DocumentTypeRequirement.Instructions = &quot;One File is required&quot;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;else if cdrBuildingApplication.ActualValuation &amp;gt;= 100000 then&lt;/p&gt;&#xD;&#xA;&lt;p&gt;DocumentTypeRequirement.MinimumRequired = 2&lt;/p&gt;&#xD;&#xA;&lt;p&gt;DocumentTypeRequirement.Instructions = &quot;Two Files are required&quot;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;else if cdrBuildingApplication.ActualValuation &amp;gt;= 500000 then&lt;/p&gt;&#xD;&#xA;&lt;p&gt;DocumentTypeRequirement.MinimumRequired = 3&lt;/p&gt;&#xD;&#xA;&lt;p&gt;DocumentTypeRequirement.Instructions = &quot;Three Files are required&quot;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;end if&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;br /&gt;end if&lt;br /&gt;&lt;br /&gt;'Set different instructions for different Portal user types&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;br /&gt;if TypeOf DocumentTypeRequirement Is Hansen.Core.Attachments.PortalDocumentTypeRequirement then&lt;/p&gt;&#xD;&#xA;&lt;p&gt;Dim returnPortalRequirementValues as Hansen.Core.Attachments.PortalDocumentTypeRequirement&lt;/p&gt;&#xD;&#xA;&lt;p&gt;returnPortalRequirementValues = CType(DocumentTypeRequirement, Hansen.Core.Attachments.PortalDocumentTypeRequirement)&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;returnPortalRequirementValues.PortalInstructions.Add(&quot;Customer&quot;, &quot;Instructions for customer user type&quot;)&lt;/p&gt;&#xD;&#xA;&lt;p&gt;returnPortalRequirementValues.PortalInstructions.Add(&quot;Public&quot;, &quot;Instructions for public user type&quot;)&lt;/p&gt;&#xD;&#xA;&lt;p&gt;returnPortalRequirementValues.PortalInstructions.Add(&quot;Provider&quot;, &quot;Instructions for provider user type&quot;)&lt;/p&gt;&#xD;&#xA;&lt;p&gt;end if&lt;/p&gt;"/>
			<record name="Core.AttachmentsXDocumentTypeXDocumentTypePermissionRule"
			        EVENTKEY="0"
			        PRODFAMILYNAME="Core.Attachments"
			        BUSOBJNAME="DocumentType"
			        PAGENAME=""
			        NAME="DocumentTypePermissionRule"
			        NAMESPACE="Core.Attachments"
			        METHODPREFIX="DTPR"
			        METHODSIGNATURE="out Hansen.Core.Attachments.IDocumentTypePermission DocumentTypePermission,  Hansen.Core.Business.IComponent Parent"
			        DEFAULTDLLNAME="Attachments"
			        DEFAULTCOMMENT="&lt;p&gt;This event is used to indicate any action permissions to be turned off for a document type in association with a specific parent record.&amp;nbsp; The parent of the attachments will be available through the Parent parameter. When returning the permissons for CDR applications, licenses, or cases, the parent may be a BuildingApplication, LicenseApplication, Case, PlanningApplication, ProjectApplication, TradeLicense, or UseApplication.&lt;/p&gt;&#xD;&#xA;&lt;p&gt;The action permission information is returned using either a Hansen.Core.Attachments.DocumentTypePermission object or a Hansen.Core.Attachments.PortalDocumentTypePermission object.&amp;nbsp;&amp;nbsp;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;The following property on the Hansen.Core.Attachments.DocumentTypePermission object is available:&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;em&gt;Permissions&lt;/em&gt;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;Bitwise flag used to indicate which permissions are to be turned off.&amp;nbsp; The Hansen.Core.DocumentManagement.DocumentPermissions enumeration can be used to populate the flag.&amp;nbsp; Options to turn off List, Open, Add, Update, and Delete actions.&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;The following property is available in the PortalDocumentTypeRequrement object in addition to the one shown above:&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;em&gt;PortalPermissions&lt;/em&gt;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;Allows for different permissions to be turned off based on the user type.&amp;nbsp; This is a dictionary with the user type as the key and a DocumentTypePermission object as the value.&amp;nbsp; If no permissions are entered for a specific user type, the system will use the permissions from the Permissions property.&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;br /&gt;Example using the DocumentTypePermission object:&lt;/p&gt;&#xD;&#xA;&lt;p&gt;DocumentTypePermission = new Hansen.Core.Attachments.DocumentTypePermission&lt;/p&gt;&lt;br/&gt;&#xD;&#xA;&lt;p&gt;' Cast the attachment parent to a CDR BuildingApplication&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;br /&gt;if TypeOf Parent Is Hansen.CDR.Building.IBuildingApplication then&lt;/p&gt;&#xD;&#xA;&lt;p&gt;Dim cdrBuildingApplication as Hansen.CDR.Building.IBuildingApplication&lt;/p&gt;&#xD;&#xA;&lt;p&gt;cdrBuildingApplication = CType(Parent, Hansen.CDR.Building.IBuildingApplication)&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;if cdrBuildingApplication.ActualValuation &amp;lt; 100000 then&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; DocumentTypePermission.Permissions =&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Hansen.Core.DocumentManagement.Services.DocumentPermissions.Add or&lt;/p&gt;&#xD;&#xA;&lt;p&gt;Hansen.Core.DocumentManagement.Services.DocumentPermissions.Update or&lt;/p&gt;&#xD;&#xA;&lt;p&gt;Hansen.Core.DocumentManagement.Services.DocumentPermissions.Delete&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp; &amp;nbsp; end if&lt;/p&gt;&#xD;&#xA;&lt;p&gt;end if&lt;br /&gt;&lt;br /&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;Example using the PortalDocumentTypePermission object:&lt;/p&gt;&#xD;&#xA;&lt;p&gt;Dim returnPortalPermissions as new Hansen.Core.Attachments.PortalDocumentTypePermission&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;' Cast the attachment parent to a CDR BuildingApplication&lt;/p&gt;&#xD;&#xA;&lt;p&gt;if TypeOf Parent Is Hansen.CDR.Building.IBuildingApplication then&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp; &amp;nbsp; Dim cdrBuildingApplication as Hansen.CDR.Building.IBuildingApplication&lt;/p&gt;&#xD;&#xA;&lt;p&gt;	cdrBuildingApplication = CType(Parent, Hansen.CDR.Building.IBuildingApplication)&lt;/p&gt;&#xD;&#xA;&lt;p&gt;	if cdrBuildingApplication.ActualValuation &lt; 100000 then&lt;/p&gt;&#xD;&#xA;&lt;p&gt;		'These settings will be used if a specific portal user type is not set in PortalPermisssions&lt;/p&gt;&#xD;&#xA;&lt;p&gt;		DocumentTypePermission.Permissions = Hansen.Core.DocumentManagement.Services.DocumentPermissions.Add or Hansen.Core.DocumentManagement.Services.DocumentPermissions.Update or Hansen.Core.DocumentManagement.Services.DocumentPermissions.Delete&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp; &amp;nbsp; end if&lt;/p&gt;&#xD;&#xA;&lt;p&gt;end if&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp; &amp;nbsp;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;'Set Customer permissions&lt;/p&gt;&#xD;&#xA;&lt;p&gt;Dim customerPermissions as Hansen.Core.Attachments.DocumentTypePermission&lt;/p&gt;&#xD;&#xA;&lt;p&gt;customerPermissions = new Hansen.Core.Attachments.DocumentTypePermission&lt;/p&gt;&#xD;&#xA;&lt;p&gt;customerPermissions.Permissions = Hansen.Core.DocumentManagement.Services.DocumentPermissions.Open&lt;/p&gt;&#xD;&#xA;&lt;p&gt;returnPortalPermissions.PortalPermissions.Add(&quot;Customer&quot;, customerPermissions)&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp; &amp;nbsp; &lt;/p&gt;&#xD;&#xA;&lt;p&gt;'Set Public permissions&lt;/p&gt;&#xD;&#xA;&lt;p&gt;Dim publicPermissions as Hansen.Core.Attachments.DocumentTypePermission&lt;/p&gt;&#xD;&#xA;&lt;p&gt;publicPermissions = new Hansen.Core.Attachments.DocumentTypePermission&lt;/p&gt;&#xD;&#xA;&lt;p&gt;publicPermissions.Permissions = Hansen.Core.DocumentManagement.Services.DocumentPermissions.Update or Hansen.Core.DocumentManagement.Services.DocumentPermissions.Delete&lt;/p&gt;&#xD;&#xA;&lt;p&gt;returnPortalPermissions.PortalPermissions.Add(&quot;Public&quot;, publicPermissions )&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&amp;nbsp; &amp;nbsp; &lt;/p&gt;&#xD;&#xA;&lt;p&gt;'Return the permissions&lt;/p&gt;&#xD;&#xA;&lt;p&gt;DocumentTypePermission = returnPortalPermissions&lt;/p&gt;&#xD;&#xA;"/>
			<record name="CDR.BuildingXBuildingApplicationXCustomValidatePortalAttachments"
			        EVENTKEY="0"
			        PRODFAMILYNAME="CDR.Building"
			        BUSOBJNAME="BuildingApplication"
			        PAGENAME=""
			        NAME="CustomValidatePortalAttachments"
			        NAMESPACE="CDR.Building"
			        METHODPREFIX="CVPA"
			        METHODSIGNATURE="Hansen.CDR.Building.IBuildingApplication BuildingApplication"
			        DEFAULTDLLNAME="CDRBuilding"
			        DEFAULTCOMMENT="&amp;lt;p&amp;gt;This event is defined to custom validate data entered by the user in the submit instrument portlet in portal.  This event is invoked when user leaves the attachment tab to prevent them from going foward if invalid data is entered.&amp;lt;/p&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;p&amp;gt;All validation messages should be created as a Hansen.Core.Result with ResultSeverity equal to UserError.&amp;lt;/p&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;p&amp;gt;A validation message can be displayed on the control level by adding the portal control id to the properties list of the Result.  If a portal control is not added to the properties list, the validation message will display at the top of the page.&amp;lt;/p&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;p&amp;gt;The following example will create a control level validation message and a page level validation message&amp;lt;/p&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;Dim res as Hansen.Core.Result = Result.Success&#xD;&#xA;&amp;lt;BR&amp;gt;if BuildingApplication.ApplicationType.ApplicationType = &amp;quot;SFD&amp;quot; Then&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;InforClient.CDRAgency.CustomDetails oCustomDetails = InforClient.CDRAgency.CustomDetails.GetInstanceFromParent(BuildingApplication.ApplicationDetails[0], ref res)&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt; &amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;#39;Page level message&#xD;&#xA;&amp;lt;BR&amp;gt; &amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;if oCustomDetails.IsApproved = false Then&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;Dim resApp as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &amp;quot;You must check the box that you approve the terms of this application.&amp;quot;)&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;res += resApp&#xD;&#xA;&amp;lt;BR&amp;gt; &amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;End if&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;#39;Control level message&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;if oCustomDetails.CustomComments.Length &amp;lt; 100 Then&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;Dim resCom as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &amp;quot;Details Comments must be greater than 100 characters.&amp;quot;)&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;resCom.properties.Add( &amp;quot;validationError&amp;quot;, &amp;quot;CustomComments&amp;quot; )&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;res += resCom&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;End If&#xD;&#xA;&amp;lt;BR&amp;gt;End if&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;#39;Attachment level message&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;if BuildingApplication.Application.Attachments.Count = 0 Then&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;Dim resAttach as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &amp;quot;At least one attachment must be uploaded.&amp;quot;)&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;resAttach.properties.Add( &amp;quot;validationError&amp;quot;, &amp;quot;attachments&amp;quot; )&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;res += resAttach&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;End If&#xD;&#xA;&amp;lt;BR&amp;gt;End if&#xD;&#xA;&amp;lt;BR&amp;gt;return res&#xD;&#xA;"/>
			<record name="CDR.BusinessLicenseXLicenseApplicationXCustomValidatePortalAttachments"
			        EVENTKEY="0"
			        PRODFAMILYNAME="CDR.BusinessLicense"
			        BUSOBJNAME="LicenseApplication"
			        PAGENAME=""
			        NAME="CustomValidatePortalAttachments"
			        NAMESPACE="CDR.BusinessLicense"
			        METHODPREFIX="CVPA"
			        METHODSIGNATURE="Hansen.CDR.BusinessLicense.ILicenseApplication LicenseApplication"
			        DEFAULTDLLNAME="CDRBusinessLicense"
			        DEFAULTCOMMENT="&amp;lt;p&amp;gt;This event is defined to custom validate data entered by the user in the submit instrument portlet in portal.  This event is invoked when user leaves the attachment tab to prevent them from going foward if invalid data is entered.&amp;lt;/p&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;p&amp;gt;All validation messages should be created as a Hansen.Core.Result with ResultSeverity equal to UserError.&amp;lt;/p&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;p&amp;gt;A validation message can be displayed on the control level by adding the portal control id to the properties list of the Result.  If a portal control is not added to the properties list, the validation message will display at the top of the page.&amp;lt;/p&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;p&amp;gt;The following example will create a control level validation message and a page level validation message&amp;lt;/p&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;Dim res as Hansen.Core.Result = Result.Success&#xD;&#xA;&amp;lt;BR&amp;gt;if LicenseApplication.LicenseType.LicenseType = &amp;quot;SFD&amp;quot; Then&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;InforClient.CDRAgency.CustomDetails oCustomDetails = InforClient.CDRAgency.CustomDetails.GetInstanceFromParent(LicenseApplication.LicenseDetails[0], ref res)&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt; &amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;#39;Page level message&#xD;&#xA;&amp;lt;BR&amp;gt; &amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;if oCustomDetails.IsApproved = false Then&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;Dim resApp as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &amp;quot;You must check the box that you approve the terms of this application.&amp;quot;)&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;res += resApp&#xD;&#xA;&amp;lt;BR&amp;gt; &amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;End if&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;#39;Control level message&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;if oCustomDetails.CustomComments.Length &amp;lt; 100 Then&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;Dim resCom as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &amp;quot;Details Comments must be greater than 100 characters.&amp;quot;)&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;resCom.properties.Add( &amp;quot;validationError&amp;quot;, &amp;quot;CustomComments&amp;quot; )&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;res += resCom&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;End If&#xD;&#xA;&amp;lt;BR&amp;gt;End if&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;#39;Attachment level message&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;if LicenseApplication.Application.Attachments.Count = 0 Then&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;Dim resAttach as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &amp;quot;At least one attachment must be uploaded.&amp;quot;)&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;resAttach.properties.Add( &amp;quot;validationError&amp;quot;, &amp;quot;attachments&amp;quot; )&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;res += resAttach&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;End If&#xD;&#xA;&amp;lt;BR&amp;gt;End if&#xD;&#xA;&amp;lt;BR&amp;gt;return res&#xD;&#xA;"/>
			<record name="CDR.CodeEnforcementXCaseXCustomValidatePortalAttachments"
			        EVENTKEY="0"
			        PRODFAMILYNAME="CDR.CodeEnforcement"
			        BUSOBJNAME="Case"
			        PAGENAME=""
			        NAME="CustomValidatePortalAttachments"
			        NAMESPACE="CDR.CodeEnforcement"
			        METHODPREFIX="CVPA"
			        METHODSIGNATURE="Hansen.CDR.CodeEnforcement.ICase Case"
			        DEFAULTDLLNAME="CDRCodeEnforcement"
			        DEFAULTCOMMENT="&amp;lt;p&amp;gt;This event is defined to custom validate data entered by the user in the submit instrument portlet in portal.  This event is invoked when user leaves the attachment tab to prevent them from going foward if invalid data is entered.&amp;lt;/p&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;p&amp;gt;All validation messages should be created as a Hansen.Core.Result with ResultSeverity equal to UserError.&amp;lt;/p&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;p&amp;gt;A validation message can be displayed on the control level by adding the portal control id to the properties list of the Result.  If a portal control is not added to the properties list, the validation message will display at the top of the page.&amp;lt;/p&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;p&amp;gt;The following example will create a control level validation message and a page level validation message&amp;lt;/p&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt;Dim res as Hansen.Core.Result = Result.Success&#xD;&#xA;&amp;lt;BR&amp;gt;if Case.CaseType.CaseType = &amp;quot;SFD&amp;quot; Then&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;InforClient.CDRAgency.CustomDetails oCustomDetails = InforClient.CDRAgency.CustomDetails.GetInstanceFromParent(Case.CaseDetails[0], ref res)&#xD;&#xA;&amp;lt;BR&amp;gt;&#xD;&#xA;&amp;lt;BR&amp;gt; &amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;#39;Page level message&#xD;&#xA;&amp;lt;BR&amp;gt; &amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;if oCustomDetails.IsApproved = false Then&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;Dim resApp as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &amp;quot;You must check the box that you approve the terms of this application.&amp;quot;)&#xD;&#xA;&amp;lt;BR&amp;gt;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;nbsp;&amp;amp;n