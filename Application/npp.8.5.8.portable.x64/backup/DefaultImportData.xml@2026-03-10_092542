			<record name="AssetManagementXAssetInspectionIndexXSMNIndexCalc"
			        EVENTKEY="1949"
			        PRODFAMILYNAME="AssetManagement"
			        BUSOBJNAME="AssetInspectionIndex"
			        PAGENAME=""
			        NAME="SMNIndexCalc"
			        NAMESPACE="AssetManagement"
			        METHODPREFIX="SMNCI"
			        METHODSIGNATURE="out System.Double IndexRating, System.String InspType, System.Int32 InspKey, Hansen.AssetManagement.Sewer.ISewerMain oAsset"
			        DEFAULTDLLNAME="AssetManagement"
			        DEFAULTCOMMENT="&lt;P&gt;This formula is used&amp;nbsp; to calculate an index for an asset inspection.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&lt;STRONG&gt;The following parameters are available to use&lt;/STRONG&gt;:&lt;BR&gt;&lt;FONT color=#ff0000&gt;InspKey&lt;/FONT&gt; - The inspection key of the inspection for which the index is calculated.&lt;BR&gt;&lt;FONT color=#ff0000&gt;oAsset&lt;/FONT&gt; - The water hydrant business object.&amp;nbsp; A list of inspections for this asset can be found at oAsset.ServiceInspections&lt;BR&gt;&lt;FONT color=#ff0000&gt;IndexRating&lt;/FONT&gt; - The calculated index should be assigned to this System.Double parameter.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&lt;STRONG&gt;Below is a sample formula that will find the current inspection and set the IndexRating value to the value of&amp;nbsp;the &quot;Flow&quot;&lt;/STRONG&gt;&amp;nbsp;&lt;STRONG&gt;property on the &quot;AgencyID.Inspections.Flow&quot; agency business object.&lt;/STRONG&gt;&lt;/P&gt;&#xA;&#xD;&lt;P&gt;Dim res As Hansen.Core.Result&lt;BR&gt;Dim oInsp As Hansen.AssetManagement.Sewer.ISMNServiceInspection&lt;/P&gt;&#xA;&#xD;&lt;P&gt;For Each oInsp In oAsset.ServiceInspections&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; If InspKey = oInsp.PrimaryKey Then&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; Dim oFlow as AgencyID.Inspections.Flow&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; oFlow = AgencyID.Inspections.Flow.GetInstanceFromParent&amp;nbsp;(oInsp,res)&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; IndexRating = oFlow.Flow&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; Exit For&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; End If&lt;BR&gt;Next&lt;/P&gt;"/>
