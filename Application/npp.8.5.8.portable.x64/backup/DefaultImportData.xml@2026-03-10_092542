			        NAME="ION Exp Custom SQL"
			        DESCRIPTION="Sample on how to load a collection of components with a custom SQL string and export the collection to ION"
			        CATEGORY="1014"
			        CODE="'Sample on how to load a collection of components with a custom SQL string and export the collection to ION&#xD;&#xA;        Dim res As Result = Result.Success&#xD;&#xA;        Dim journals As IJournalRunCollection = ServerApplication.NewReadOnlyComponent(Of IJournalRunCollection)()&#xD;&#xA;        Dim reader As System.Data.IDataReader = Nothing&#xD;&#xA;        'Sample custom SQL statement and parameter&#xD;&#xA;        Const sql As String = &quot;SELECT * FROM BILLING.JOURNALRUN WHERE JOURNALRUNKEY &gt; @minJournalKey&quot;&#xD;&#xA;&#xD;&#xA;        Dim parameters As New DBParameterCollection()&#xD;&#xA;        parameters.Add(New DBParameter(&quot;@minJournalKey&quot;, 1))&#xD;&#xA;&#xD;&#xA;        res += DataServices.ExecSQL(journals.UserInfo.UsersDefaultProvider, sql, parameters, reader)&#xD;&#xA;        If (res.IsSuccess) Then&#xD;&#xA;            res += Hansen.Core.Data.Mapping.DataReaderMapper.MapToComponentCollection(reader, journals)&#xD;&#xA;            If (res.IsSuccess) Then&#xD;&#xA;                res += Hansen.Core.Messaging.MessagingService.Send(journals, Hansen.Core.Messaging.MessageTrigger.Added) 'The MessageTrigger will be specific to the action or None if there is no action&#xD;&#xA;            End If&#xD;&#xA;        End If&#xD;&#xA;&#xD;&#xA;        Return res"/>
