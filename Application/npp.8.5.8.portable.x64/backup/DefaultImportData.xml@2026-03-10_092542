			        NAME="AutoStatusChangePROJ"
			        NAMESPACE="CDR.Project"
			        METHODPREFIX="AS"
			        METHODSIGNATURE="out System.String StatusCode, Hansen.CDR.Project.IProjectApplication oProjApp"
			        DEFAULTDLLNAME="CDRPlanning"
			        DEFAULTCOMMENT="This AutoStatusChangePROJ Event is for determining the new status of a planning condition after a milestone has been reached within a Project Application.&lt;br&gt;&lt;br&gt;Available to be used within the calculation is a ProjectApplication object expressed as '&lt;b&gt;oProjApp&lt;/b&gt;'. The new desired status should be return as a string through the variable names '&lt;b&gt;StatusCode&lt;/b&gt;'. &lt;b&gt;StatusCode&lt;/b&gt; should be a valid code for one of the predefined Planning Condition Statuses.&lt;br&gt;&lt;br&gt;&lt;i&gt;Example:&amp;nbsp;&amp;nbsp;(Assumes the Planning Condition Statuses '&lt;b&gt;In Effect&lt;/b&gt;' and '&lt;b&gt;Met&lt;/b&gt;' are defined.)&lt;/i&gt;&lt;br&gt;&lt;span style='font-size:10.0pt;font-family:&quot;Courier New&quot;'&gt;&lt;span style='color:blue'&gt;If&lt;/span&gt;(oProjApp.CheckFeeStatus()==0)&lt;span style='color:blue'&gt;Then&lt;/span&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;StatusCode = &quot;&lt;span style='color:purple'&gt;Met&lt;/span&gt;&quot;&lt;br&gt;&lt;span style='color:blue'&gt;Else&lt;/span&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;StatusCode = &quot;&lt;span style='color:purple'&gt;In Effect&lt;/span&gt;&quot;&lt;br&gt;&lt;span style='color:blue'&gt;End If&lt;/span&gt;&lt;/span&gt;"/>
