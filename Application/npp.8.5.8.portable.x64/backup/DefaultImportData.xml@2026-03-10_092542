			        NAMESPACE="CDR.BusinessLicense"
			        METHODPREFIX="MB"
			        METHODSIGNATURE="out System.Decimal MinBalance, Hansen.CDR.BusinessLicense.ILicenseApplication oLicenseApp, Hansen.CDR.IFee Fee"
			        DEFAULTDLLNAME="CDRBusinessLicense"
			        DEFAULTCOMMENT="&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;FONT size=2&gt;This event is defined to calculate the minimum balance of the trust account.&lt;SPAN style=&quot;mso-spacerun: yes&quot;&gt;&amp;nbsp; &lt;/SPAN&gt;The returned value needs to be set into the MinBalance variable.&lt;SPAN style=&quot;mso-spacerun: yes&quot;&gt;&amp;nbsp; &lt;/SPAN&gt;In the following example, the minimum balance is 25% of the “ADDITIONAL DEPOSIT” fee if there is one.&lt;SPAN style=&quot;mso-spacerun: yes&quot;&gt;&amp;nbsp; &lt;/SPAN&gt;Otherwise, it is $50.00.&lt;/FONT&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;?xml:namespace prefix = o ns = &quot;urn:schemas-microsoft-com:office:office&quot; /&gt;&lt;o:p&gt;&lt;FONT size=2&gt;&amp;nbsp;&lt;/FONT&gt;&lt;/o:p&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;FONT size=2&gt;Example: &lt;/FONT&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;FONT size=2&gt;Dim oFee as Hansen.CDR.IFee&lt;/FONT&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;FONT size=2&gt;MinBalance = 50.00&lt;/FONT&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;o:p&gt;&lt;FONT size=2&gt;&amp;nbsp;&lt;/FONT&gt;&lt;/o:p&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;FONT size=2&gt;for each oFee in oLicenseApp.Application.Fees&lt;/FONT&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;FONT size=2&gt;&lt;SPAN style=&quot;mso-spacerun: yes&quot;&gt;&amp;nbsp;&amp;nbsp; &lt;/SPAN&gt;if oFee.FeeDescription.ToUpper = &quot;ADDITIONAL DEPOSIT&quot; then &lt;/FONT&gt;&lt;/P&gt;&#xA;&#xD;&lt;P class=MsoNormal style=&quot;MARGIN: 0in 0in 0pt&quot;&gt;&lt;FONT size=2&gt;&lt;SPAN style=&quot;mso-spacerun: yes&quot;&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt