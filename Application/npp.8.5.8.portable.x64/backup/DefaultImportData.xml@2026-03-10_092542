			        DEFAULTDLLNAME="CDRPlanning"
			        DEFAULTCOMMENT="This CheckInheritanceBLDG Event is for determining if a building application should inherit a planning condition.&lt;br&gt;&lt;br&gt;Available to be used withing the calculation is a BuildingApplication object expressed as '&lt;b&gt;oBldgApp&lt;/b&gt;'. The result should be a boolean variable returned through the variable named '&lt;b&gt;InheritanceCheck&lt;/b&gt;'.&lt;br&gt;&lt;br&gt;&lt;i&gt;Example:&lt;/i&gt;&lt;br&gt;&lt;span style='font-size:10.0pt;font-family:&quot;Courier New&quot;'&gt;&lt;span style='color:blue'&gt;If&lt;/span&gt;(oBldgApp.NumberOfPlans&gt;5) &lt;span style='color:blue'&gt;Then&lt;/span&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;InheritanceCheck = &lt;span style='color:blue'&gt;True&lt;/span&gt;&lt;br&gt;&lt;span style='color:blue'&gt;Else&lt;/span&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;InheritanceCheck = &lt;span style='color:blue'&gt;False&lt;/span&gt;&lt;br&gt;&lt;span style='color:blue'&gt;End If&lt;/span&gt;"/>
