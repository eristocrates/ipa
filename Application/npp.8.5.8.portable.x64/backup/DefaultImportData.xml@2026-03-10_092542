			        DEFAULTDLLNAME="CDRUse"
			        DEFAULTCOMMENT="&lt;p&gt;This event is defined to custom validate data entered by the user in the submit instrument portlet in portal.  This event is invoked when user leaves the Location tab to prevent them from going foward if invalid data is entered.&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;p&gt;All validation messages should be created as a Hansen.Core.Result with ResultSeverity equal to UserError.&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;p&gt;A validation message can be displayed on the control level by adding the portal control id to the properties list of the Result.  If a portal control is not added to the properties list, the validation message will display at the top of the page.&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;p&gt;The following example will create a control level validation message and a page level validation message&lt;/p&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;Dim res as Hansen.Core.Result = Result.Success&#xD;&#xA;&lt;BR&gt;if oUseApplication.ApplicationType.ApplicationType = &quot;SFD&quot; Then&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;'Page level message&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;if oUseApplication.OccupancyType.Code = &quot;RES&quot; and oUseApplication.Location.Length = 0 Then&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Dim resOcc as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &quot;Location cannot be empty for this Occupancy Type.&quot;)&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;res += resOcc&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;End if&#xD;&#xA;&lt;BR&gt;&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;'Control level message&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;if oUseApplication.Location.Length &lt; 100 Then&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Dim resLoc as Hansen.Core.Result = new Result(1, ResultSeverity.UserError, &quot;Location Description must be greater than 100 characters.&quot;)&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;resLoc.properties.Add( &quot;validationError&quot;, &quot;locationDetails&quot; )&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;res += resLoc&#xD;&#xA;&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;End If&#xD;&#xA;&lt;BR&gt;End if&#xD;&#xA;&lt;BR&gt;return res"/>
