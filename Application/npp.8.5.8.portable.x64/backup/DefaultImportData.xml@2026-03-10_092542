			<record name="1067"
			        SNIPPETKEY="1067"
			        NAME="Send Email from Template"
			        DESCRIPTION="Sends an email based on a specified email template ID that uses Hansen.CRM.IServiceRequest as the input parameter.&#xD;&#xA;This will use the Language Settings from the provided Contact Key to get the correct Email Template for that language.&#xD;&#xA;The email will be sent to the email address listed for the provided Contact Key.&#xD;&#xA;The email settings from the Hansen8 configuration are used to determine the &quot;from&quot; address as well the SMTP server information."
			        CATEGORY="1010"
			        CODE="'***********************************************************************************&#xD;&#xA;'  Send Email from Template&#xD;&#xA;'&#xD;&#xA;'  This code snippet sends an email based on a specified email template ID &#xD;&#xA;'   that uses Hansen.CRM.IServiceRequest as the input parameter.&#xD;&#xA;'  The input parameter is specified in the Template Setup&#xD;&#xA;&#xD;&#xA;'  This will use the Language Settings from the provided Contact Key to get the correct Email Template for that language.&#xD;&#xA;'  The email will be sent to the email address listed for the provided Contact Key.&#xD;&#xA;'  The email settings from the Hansen8 configuration are used to determine the &quot;from&quot; address as well the SMTP server information.&#xD;&#xA;'&#xD;&#xA;'**********************************************************************************&#xD;&#xA;&#xD;&#xA;return EMail.SendMailFromTemplate(&quot;TemplateId&quot;, ContactKey, oServiceRequest)"/>
			<record name="1068"
			        SNIPPETKEY="1068"
			        NAME="Use Email as User Name"
			        DESCRIPTION="Enforces the Portal Membership table to use the Contact's Email Address as the User Name"
			        CATEGORY="1010"
			        CODE="'***********************************************************************************&#xD;&#xA;'  Use Email As User Name&#xD;&#xA;'&#xD;&#xA;'  This code snippet can be added to a Portal.Membership BeforeAdd formula&#xD;&#xA;'  to enforce using the Contact's email address as the User Name.&#xD;&#xA;'&#xD;&#xA;'  This code snippet will check that the User Name equals the Contact's email address&#xD;&#xA;'  and output a message to the user if they do not match.&#xD;&#xA;'&#xD;&#xA;'**********************************************************************************&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;dim res as Hansen.Core.Result&#xD;&#xA;if oMembership.UserName &lt;&gt; oMembership.Contact.EMailAddress then&#xD;&#xA;	res = new Hansen.Core.Result(1, ResultSeverity.UserError, &quot;User Name must be the Contact's Email Address&quot; )&#xD;&#xA;end if&#xD;&#xA;&#xD;&#xA;return res"/>
			<record name="1069"
			        SNIPPETKEY="1069"
			        NAME="Formula calling assembly"
			        DESCRIPTION="Sample of a formula calling an internal formula that calls a custom assembly."
			        CATEGORY="1026"
			        CODE="'Calling formula Validation from within a formula&#xD;&#xA;&#xD;&#xA;dim retval as Object&#xD;&#xA;ServerApplication.InvokeSpecificEvent(&quot;Hansen.Billing.DelinquencyMilestone&quot;, &quot;NextMilestoneFormula&quot;, &quot;Validation&quot;, oAccount.UserInfo, retval, oAccount, oAccountDelinquency)&#xD;&#xA;sResolutionCode = retval.ToString()"/>
			<record name="1070"
			        SNIPPETKEY="1070"
			        NAME="Check For Holiday"
			        DESCRIPTION="Checks to see if the current scheduled inspection date is a holiday as defined on the resource holidays applet."
			        CATEGORY="1009"
			        CODE="'CheckHoliday&#xD;&#xA;'This snippet is used to check the Hansen.Resources.Holiday table for a scheduled inspection that is added on a holiday.&#xD;&#xA;'Holidays are managed on the Resource Holidays Screen (RH).&#xD;&#xA;'This should be used with scheduled inspections and intended for use with Inspection Events.&#xD;&#xA;&#xD;&#xA;Dim res as result&#xD;&#xA;Dim holiday as Hansen.Resources.IHoliday&#xD;&#xA;Dim holidayDate as DateTime&#xD;&#xA;&#xD;&#xA;holiday = ServerApplication.NewComponent (&quot;Hansen.Resources.Holiday&quot;, oInspection.UserInfo)&#xD;&#xA;holidayDate = new DateTime(oInspection.ScheduledDateTime.Year, oInspection.ScheduledDateTime.Month, oInspection.ScheduledDateTime.Day)&#xD;&#xA;holiday.HolidayDate = holidayDate&#xD;&#xA;res = holiday.LoadByKey()&#xD;&#xA;&#xD;&#xA;If res.IsNoDataFound = False then&#xD;&#xA;	&#xD;&#xA;	&#xD;&#xA;	res = new Result( 0, ResultSeverity.UserError, &quot;Unable to schedule selected date because it is a holiday&quot; )&#xD;&#xA;	&#xD;&#xA;End if&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;return res"/>
			<record name="1071"
			        SNIPPETKEY="1071"
			        NAME="Check For Holiday"
			        DESCRIPTION="Checks to see if the current scheduled inspection date is a holiday as defined on the resource holidays applet."
			        CATEGORY="1008"
			        CODE="'CheckHoliday&#xD;&#xA;'This snippet is used to check the Hansen.Resources.Holiday table for a scheduled inspection that is added on a holiday.&#xD;&#xA;'Holidays are managed on the Resource Holidays Screen (RH).&#xD;&#xA;'This should be used with scheduled inspections and intended for use with Service Request Events.&#xD;&#xA;&#xD;&#xA;Dim res as result&#xD;&#xA;Dim holiday as Hansen.Resources.IHoliday&#xD;&#xA;Dim holidayDate as DateTime&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;holiday = ServerApplication.NewComponent (&quot;Hansen.Resources.Holiday&quot;, oServiceRequest.UserInfo)&#xD;&#xA;holidayDate = new DateTime(oServiceRequest.ScheduledStartDateTime.Year, oServiceRequest.ScheduledStartDateTime.Month, oServiceRequest.ScheduledStartDateTime.Day)&#xD;&#xA;holiday.HolidayDate = holidayDate&#xD;&#xA;res = holiday.LoadByKey()&#xD;&#xA;&#xD;&#xA;If res.IsNoDataFound = False then&#xD;&#xA;	&#xD;&#xA;	&#xD;&#xA;	res = new Result( 0, ResultSeverity.UserError, &quot;Unable to schedule selected date because it is a holiday&quot; )&#xD;&#xA;	&#xD;&#xA;End if&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;return res"/>
			<record name="1072"
			        SNIPPETKEY="1072"
			        NAME="Internal Contact Query"
			        DESCRIPTION="Method calls to determine if the logged in employee or a given employee id is an internal contact or not. Over load accepts Role Code also."
			        CATEGORY="1013"
			        CODE="        Dim result As Hansen.Core.Result = result.Success&#xD;&#xA;        Dim account As Hansen.Billing.IAccount = ServerApplication.NewComponent(Of Hansen.Billing.IAccount)()&#xD;&#xA;        Dim accounts As Hansen.Billing.IAccountCollection = ServerApplication.NewComponent(Of Hansen.Billing.IAccountCollection)()&#xD;&#xA;        Dim flag As Boolean = False&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;        'flag will be true if the logged in employee id is one of the Internal contact of the account.&#xD;&#xA;        result = account.IsInternalContact(flag)&#xD;&#xA;&#xD;&#xA;        'flag will be true if the employee id 'jsmith' is one of the Internal contact of the account.&#xD;&#xA;        result = account.IsInternalContact(&quot;jsmith&quot;, flag)&#xD;&#xA;&#xD;&#xA;        'flag will be true if the employee id 'jsmith' as MBM role  in the account&#xD;&#xA;        result = account.IsInternalContact(&quot;jsmith&quot;, &quot;MBM&quot;, flag)&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;        'loads the list of accounts where the logged in employee is one of the internal contact&#xD;&#xA;        result = accounts.LoadAccountsByInternalContact()&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;        'loads the list of accounts where the employee id jsmith is one of the internal contact&#xD;&#xA;        result = accounts.LoadAccountsByInternalContact(&quot;jsmith&quot;)&#xD;&#xA;&#xD;&#xA;        'loads the list of accounts where the employee id jsmith is one of the internal contact with the role as 'AccountManager'&#xD;&#xA;        result = accounts.LoadAccountsByInternalContact(&quot;jsmith&quot;, &quot;AccountManager&quot;)"/>
			<record name="1073"
			        SNIPPETKEY="1073"
			        NAME="Send with message"
			        DESCRIPTION="Sends a notification to the contact defined in the work order &quot;Assigned To&quot; property.  This notification specifies a custom message that could be included in the notification template (if a template is associated with the notification type in the configuration).  If no template is defined, the message will be sent in plain text."
			        CATEGORY="1028"
			        CODE="'Send notification of type &quot;TYPE_NAME&quot; with a specific message.  The &quot;Assigned To&quot; on the work order will be used as the contact, and the work order object will be passed to the notification template (if defined).&#xD;&#xA;return Hansen.Resources.Notifications.NotificationService.Send(&quot;This message will be passed to the notification template in the {message.Message} property&quot;, &quot;TYPE_NAME&quot;, oWorkOrder, oWorkOrder.AssignedTo.Contact)"/>
			<record name="1074"
			        SNIPPETKEY="1074"
			        NAME="Send without message"
			        DESCRIPTION="Sends a notification to the contact defined in the work order &quot;Assigned To&quot; property.  This notification type should have an associated notification template to provide the message body since no custom message is provided in this code sample.  "
			        CATEGORY="1028"
			        CODE="'Send notification of type &quot;TYPE_NAME&quot; with no additional message.  The &quot;Assigned To&quot; on the work order will be used as the contact, and the work order object will be passed to the notification template (if defined).  Note that if a template is not defined, the notification will be blank since no message was provided.&#xD;&#xA;return Hansen.Resources.Notifications.NotificationService.Send(&quot;TYPE_NAME&quot;, oWorkOrder, oWorkOrder.AssignedTo.Contact)"/>
			<record name="1075"
