			        CODE="'Sample on how to load a component collection and export the collection to ION&#xD;&#xA;        Dim res As Result = Result.Success&#xD;&#xA;        Dim journals As IJournalRunCollection = ServerApplication.NewComponent(Of IJournalRunCollection)()&#xD;&#xA;        'Sample condition for loading the collection&#xD;&#xA;        Dim customWhere As New DBOperativeCollection()&#xD;&#xA;        customWhere.Add(Of IJournalRun)(Function(journal) journal.JournalRunKey &gt; 1)&#xD;&#xA;&#xD;&#xA;        res += journals.Load(customWhere, False)&#xD;&#xA;        If (res.IsSuccess AndAlso Not res.IsNoDataFound) Then&#xD;&#xA;            res += Hansen.Core.Messaging.MessagingService.Send(journals, Hansen.Core.Messaging.MessageTrigger.Added) 'The MessageTrigger will be specific to the action or None if there is no action&#xD;&#xA;        End If&#xD;&#xA;        Return res"/>
