	<defaultData name="Resources.EMAILTEMPLATE"
	             productFamily="Resources"
	             table="EMAILTEMPLATE"
	             criteria=""
	             alternateColumnsUsed="false"
	             installMethod="Install, Upgrade"
	             sortPriority="2">
		<schema>
			<column name="DESCRIPTION"
			        type="LongVarChar"
			        isPrimaryKeyColumn="false"
			        isIdentity="false"/>
			<column name="EMAILTEMPLATEKEY"
			        type="Integer"
			        isPrimaryKeyColumn="true"
			        isIdentity="false"/>
			<column name="INPUTPARAMETERS"
			        type="Varchar"
			        isPrimaryKeyColumn="false"
			        isIdentity="false"/>
			<column name="SENDASHTML"
			        type="Varchar"
			        isPrimaryKeyColumn="false"
			        isIdentity="false"
			        modification="Add"/>
			<column name="TEMPLATEID"
			        type="Varchar"
			        isPrimaryKeyColumn="false"
			        isIdentity="true"/>
		</schema>
		<data>
			<record name="1000"
			        DESCRIPTION="&lt;h3&gt;This email will be sent when creating a new user from the Contact form from within the application.&lt;/h3&gt;&lt;p&gt;The body of the email can be written in HTML&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The following parameters are available.  These parameters should be placed inside {{  }}&lt;/p&gt;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;sPassword:&lt;/font&gt;  the temporary password generated for the user&lt;/p&gt;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;oMembership:&lt;/font&gt;  the portal membership business object.  You can access any information about the membership account or the contact from this object.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;h3&gt;Below is a example using the UserName, First Name and Password.&lt;/h3&gt;&lt;p&gt;Hello {{oMembership.Contact.Identity.FirstName}},&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Your User Name is {{oMembership.UserName}}&lt;/p&gt;&lt;p&gt;and your temporary password is {{sPassword}}&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;"
			        EMAILTEMPLATEKEY="1000"
			        INPUTPARAMETERS="Hansen.Portal.IMembership oMembership, string sPassword"
			        SENDASHTML="Y"
			        TEMPLATEID="CreatePortalUser"/>
			<record name="1001"
			        DESCRIPTION="&lt;h3&gt;This email will be sent when resetting the password from within the application.&lt;/h3&gt;&lt;p&gt;The body of the email can be written in HTML&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The following parameters are available.  These parameters should be placed inside {{  }}&lt;/p&gt;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;sPassword:&lt;/font&gt;  the temporary password generated for the user&lt;/p&gt;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;oMembership:&lt;/font&gt;  the portal membership business object.  You can access any information about the membership account or the contact from this object.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;h3&gt;Below is a example using the UserName, First Name and Password.&lt;/h3&gt;&lt;p&gt;Hello {{oMembership.Contact.Identity.FirstName}},&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Your User Name is {{oMembership.UserName}}&lt;/p&gt;&lt;p&gt;and your temporary password is {{sPassword}}&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;"
			        EMAILTEMPLATEKEY="1001"
			        INPUTPARAMETERS="Hansen.Portal.IMembership oMembership, string sPassword"
			        SENDASHTML="Y"
			        TEMPLATEID="ResetPortalPassword"/>
			<record name="1002"
			        DESCRIPTION="&lt;h3&gt;This email will be sent when the password has been changed from the Portal application.&lt;/h3&gt;&lt;p&gt;The body of the email can be written in HTML&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The following parameters are available.  These parameters should be placed inside {{  }}&lt;/p&gt;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;oMembership:&lt;/font&gt;  the portal membership business object.  You can access any information about the membership account or the contact from this object.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;h3&gt;Below is a example using the UserName and First Name.&lt;/h3&gt;&lt;p&gt;Hello {{oMembership.Contact.Identity.FirstName}},&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Your User Name is {{oMembership.UserName}}&lt;/p&gt;&lt;p&gt;Your password has been changed. If you did not make this change, contact the agency at (555) 555-0101&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;"
			        EMAILTEMPLATEKEY="1002"
			        INPUTPARAMETERS="Hansen.Portal.IMembership oMembership"
			        SENDASHTML="Y"
			        TEMPLATEID="PortalPasswordChanged"/>
			<record name="1003"
			        DESCRIPTION="&lt;h3&gt;This notification will be sent when the &quot;Notify&quot; feature from Infor Field Inspector (&quot;Mobile&quot;) is used.&lt;/h3&gt;&lt;p&gt;The body of the email can be written in HTML&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The following parameters are available. These parameters should be placed inside a double curly brace (e.g. &quot;{{ }}&quot; ) surrounding the parameter name&lt;/p&gt;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;message:&lt;/font&gt; the structure containing all of the properties relevant to the notification, including the component to which it's associated, the contact who should be notified, etc.&lt;/p&gt;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;inspection&lt;/font&gt;: &lt;font color=&quot;#666666&quot;&gt;the inspection that is related to this notification from the mobile application&lt;br&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;h3&gt;Below is a example using the obtaining the message text from the mobile user and identifying the relevant contact.&lt;/h3&gt;&lt;p&gt;Hello {{message.ReferenceContact.Identity.FirstName}},&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The message from the mobile user is: {{message.Message}}&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;"
			        EMAILTEMPLATEKEY="1003"
			        INPUTPARAMETERS="Hansen.Resources.Notifications.INotificationMessage message, Hansen.CDR.ICDRInspection inspection"
			        SENDASHTML="Y"
			        TEMPLATEID="InspectionStatusUpdate_Email"/>
			<record name="1004"
			        DESCRIPTION="&lt;h3&gt;This notification will be sent when the &quot;Notify&quot; feature from Infor Field Inspector (&quot;Mobile&quot;) is used.&lt;/h3&gt;&lt;p&gt;The body of the message serves as the SMS text body and must not contain HTML.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The following parameters are available. These parameters should be placed inside a double curly brace (e.g. &quot;{{ }}&quot; ) surrounding the parameter name&lt;/p&gt;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;message:&lt;/font&gt; the structure containing all of the properties relevant to the notification, including the component to which it's associated, the contact who should be notified, etc.&lt;/p&gt;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;inspection&lt;/font&gt;: &lt;font color=&quot;#666666&quot;&gt;the inspection that is related to this notification from the mobile application&lt;br&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;h3&gt;Below is a example using the obtaining the message text from the mobile user and identifying the relevant contact.&lt;/h3&gt;&lt;p&gt;Hello {{message.ReferenceContact.Identity.FirstName}},&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The message from the mobile user is: {{message.Message}}&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;"
			        EMAILTEMPLATEKEY="1004"
			        INPUTPARAMETERS="Hansen.Resources.Notifications.INotificationMessage message, Hansen.CDR.ICDRInspection inspection"
			        SENDASHTML="N"
			        TEMPLATEID="InspectionStatusUpdate_SMS"/>
			<record name="1005"
			        DESCRIPTION="&lt;h3&gt;This email will be sent when the user registers within the Portal application.&lt;/h3&gt;&lt;p&gt;The body of the email can be written in HTML&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The following parameters are available.  These parameters should be placed inside {{  }}&lt;/p&gt;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;oMembership:&lt;/font&gt;  the portal membership business object.  You can access any information about the membership account or the contact from this object.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;h3&gt;Below is a example using the UserName and First Name.&lt;/h3&gt;&lt;p&gt;Hello {{oMembership.Contact.Identity.FirstName}},&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Your User Name is {{oMembership.UserName}}&lt;/p&gt;You must activate your account.  Click link to activate: &lt;br&gt;&lt;br&gt;&#xD;&#xA;Link: &lt;a href=&quot;http://localhost:3000/#/activationCode/{{oMembership.ActivationCode}}&quot;&gt;http://localhost:3000/#/activationCode/{{oMembership.ActivationCode}}&lt;/a&gt;&lt;br&gt;&lt;br&gt;&lt;p&gt;If you did not create this account, contact the agency at (555) 555-0101&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;"
			        EMAILTEMPLATEKEY="1005"
			        INPUTPARAMETERS="Hansen.Portal.IMembership oMembership"
			        SENDASHTML="Y"
			        TEMPLATEID="RegisterPortalUser"/>
			<record name="1006"
			        DESCRIPTION="&lt;h3&gt;This email will be sent when a payment is made in the Portal system.&lt;/h3&gt;&lt;p&gt;The body of the email can be written in HTML&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The following parameters are available.  These parameters should be placed inside {{  }}&lt;/p&gt;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;oRegTransaction:&lt;/font&gt;  the register transaction business object.  You can access any information about the register transaction or payment from this object.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;h3&gt;Below is a example.&lt;/h3&gt;&lt;p&gt; Online Payment Confirmation:&lt;br /&gt;&#xD;&#xA;            &lt;hr /&gt;&#xD;&#xA;          &#xD;&#xA;            Amount: ${{oRegTransaction.TransactionAmount}}&lt;br /&gt;&#xD;&#xA;          	Date: {{oRegTransaction.TransactionDateTime}}&#xD;&#xA;            &lt;hr /&gt;&lt;br /&gt;&#xD;&#xA;            Transaction #: {{oRegTransaction.RegisterTransactionNumber}}&lt;br /&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;"
			        EMAILTEMPLATEKEY="1006"
			        INPUTPARAMETERS="Hansen.Cashiering.IRegisterTransaction oRegTransaction, Hansen.Core.Views.IInstrument oInstrument, Hansen.Cashiering.IPaymentServerTransaction oPaymentServerTransaction"
			        SENDASHTML="Y"
			        TEMPLATEID="PortalPaymentConfirmation"/>
			<record name="1007"
			        DESCRIPTION="&lt;h3&gt;This email will be sent when inviting applicants through Civics.&lt;/h3&gt;&lt;p&gt;The body of the email can be written in HTML&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The following parameters are available.  These parameters should be placed inside {{  }}&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;oInvite:&lt;/font&gt;  the portal invitation business object.  You can access any information about the invitation record this object.&lt;/p&gt;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;sUrlParam:&lt;/font&gt;  the url parameters&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;sInstrumentType:&lt;/font&gt;  the type of the portal instrument&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;h3&gt;Below is a example using the Name and Instrument Type.&lt;/h3&gt;&lt;p&gt;Name : {{sName}},&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Instrument Type : {{sInstrumentType}},&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;"
			        EMAILTEMPLATEKEY="1007"
			        INPUTPARAMETERS="Hansen.Portal.IInvitation oInvite, string sName, string sUrlParam, string sInstrumentType"
			        SENDASHTML="Y"
			        TEMPLATEID="SendPortalInvitation"/>
			<record name="1008"
			        DESCRIPTION="&lt;h3&gt;This email will be sent when a public payment is made in the Portal system.&lt;/h3&gt;&lt;p&gt;The body of the email can be written in HTML&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The following parameters are available.  These parameters should be placed inside {{  }}&lt;/p&gt;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;oRegTransaction:&lt;/font&gt;  the register transaction business object.  You can access any information about the register transaction or payment from this object.&lt;br&gt;&lt;font color=&quot;#d5000e&quot;&gt;oInstrument:&lt;/font&gt;  the instrument business object.  You can access any information about the instrument record from this object.&#xD;&#xA;&#xD;&#xA;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;h3&gt;Below is a example.&lt;/h3&gt;&lt;p&gt; Online Payment Confirmation:&lt;br /&gt;&#xD;&#xA;            &lt;hr /&gt;&#xD;&#xA;          &#xD;&#xA;            Amount: ${{oRegTransaction.TransactionAmount}}&lt;br /&gt;&#xD;&#xA;          	Date: {{oRegTransaction.TransactionDateTime}}&#xD;&#xA;            &lt;hr /&gt;&lt;br /&gt;&#xD;&#xA;            Transaction #: {{oRegTransaction.RegisterTransactionNumber}}&lt;br /&gt;&#xD;&#xA;            Record: {{oInstrument.PortalDescription}}&lt;br /&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&#xD;&#xA;"
			        EMAILTEMPLATEKEY="1008"
			        INPUTPARAMETERS="Hansen.Cashiering.IRegisterTransaction oRegTransaction, Hansen.Core.Views.IInstrument oInstrument, Hansen.Cashiering.IPaymentServerTransaction oPaymentServerTransaction"
			        SENDASHTML="Y"
			        TEMPLATEID="PortalPublicPaymentConfirmation"/>
			<record name="1009"
			        DESCRIPTION="&lt;h3&gt;This email will be sent with a link for the recipient to pay the fees for an application, license or case.&lt;/h3&gt;&lt;p&gt;The body of the email can be written in HTML&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The following parameters are available.  These parameters should be placed inside {{  }}&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;oApplication:&lt;/font&gt;  the CDR Application business object.  You can access any information about the common application record.&lt;/p&gt;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;sPaymentURL:&lt;/font&gt;  then full url for the one time payment page&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;sInstrumentType:&lt;/font&gt;  the type of the portal instrument&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&#xD;&#xA;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;"
			        EMAILTEMPLATEKEY="1009"
			        INPUTPARAMETERS="Hansen.CDR.IApplication oApplication, string sInstrumentType, string sPaymentURL"
			        SENDASHTML="Y"
			        TEMPLATEID="SendPortalPaymentURL"/>
			<record name="1010"
			        DESCRIPTION="&lt;h3&gt;This email will be sent when a payment is made in the Portal system.&lt;/h3&gt;&lt;p&gt;The body of the email can be written in HTML&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The following parameters are available.  These parameters should be placed inside {{  }}&lt;/p&gt;&lt;p&gt;&lt;font color=&quot;#d5000e&quot;&gt;oRegTransaction:&lt;/font&gt;  the register transaction business object.  You can access any information about the register transaction or payment from this object.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;h3&gt;Below is a example.&lt;/h3&gt;&lt;p&gt; Online Payment Confirmation:&lt;br /&gt;&#xD;&#xA;            &lt;hr /&gt;&#xD;&#xA;          &#xD;&#xA;            Amount: ${{oRegTransaction.TransactionAmount}}&lt;br /&gt;&#xD;&#xA;          	Date: {{oRegTransaction.TransactionDateTime}}&#xD;&#xA;            &lt;hr /&gt;&lt;br /&gt;&#xD;&#xA;            Transaction #: {{oRegTransaction.RegisterTransactionNumber}}&lt;br /&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;"
			        EMAILTEMPLATEKEY="1010"
			        INPUTPARAMETERS="Hansen.Cashiering.IRegisterTransaction oRegTransaction, Hansen.Core.Views.IInstrument oInstrument, Hansen.Cashiering.IPaymentServerTransaction oPaymentServerTransaction"
			        SENDASHTML="Y"
