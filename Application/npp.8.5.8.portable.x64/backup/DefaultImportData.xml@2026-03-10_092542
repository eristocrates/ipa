			<record name="1096"
			        SNIPPETKEY="1096"
			        NAME="Clear Sync Artifacts"
			        DESCRIPTION="Delete all GIS Sync artifacts related to a GIS Sync Mapping."
			        CATEGORY="1033"
			        CODE="' Deletes all sync artifacts associated with the mapping.&#xD;&#xA;'   Change the following line to reference a particular mapping by name:&#xD;&#xA;dim mappingName = &quot;My City Parcels&quot;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;dim mappings as Hansen.Gis.ISyncMappingCollection = ServerApplication.NewComponent(of Hansen.Gis.ISyncMappingCollection)()&#xD;&#xA;dim operatives = new DBOperativeCollection()&#xD;&#xA;operatives.Add(new IdOperativeByCommonId(&quot;Gis&quot;, &quot;SyncMapping.Name&quot;, mappingName))&#xD;&#xA;dim res = mappings.Load(operatives, false)&#xD;&#xA;res.Assert()&#xD;&#xA;if mappings.COunt=1 then&#xD;&#xA;      dim mapping as Hansen.Gis.ISyncMapping= mappings(0)&#xD;&#xA;      mapping.DeleteArtifacts()&#xD;&#xA;else&#xD;&#xA;      throw new Exception(&quot;Mapping not found: &quot;+mappingName)&#xD;&#xA;end if&#xD;&#xA;"/>
			<record name="1098"
			        SNIPPETKEY="1098"
			        NAME="GisGetYN"
			        DESCRIPTION="Formula field to Get Y and N as booleans in GIS Source"
			        CATEGORY="1037"
			        CODE="' Example of a computed field for GIS Sync&#xD;&#xA;' This method represents a GIS field with values 'Y' or 'N' as boolean.&#xD;&#xA;' The value of the ISCURRENT attribute is interpreted as true or false.&#xD;&#xA;&#xD;&#xA;' access the gis attributes&#xD;&#xA;dim gisAttributes = oContext.GisFeature.Attributes&#xD;&#xA;&#xD;&#xA;' get the attributes we need to compute the formula&#xD;&#xA;dim sIsCurrent = gisAttributes.Item(&quot;ISCURRENT&quot;).ToString()&#xD;&#xA;&#xD;&#xA;' extract boolean value&#xD;&#xA;dim bIsCurrent as Boolean = sIsCurrent.ToUpper()=&quot;Y&quot;&#xD;&#xA;&#xD;&#xA;' return the result.  This will be the value of the computed field.&#xD;&#xA;retval = bIsCurrent&#xD;&#xA;"/>
			<record name="1099"
			        SNIPPETKEY="1099"
			        NAME="GisSetYN"
			        DESCRIPTION="Formula to set Y and N as booleans in GIS Source"
			        CATEGORY="1038"
			        CODE="' Example of a computed field for GIS Sync&#xD;&#xA;' This method represents a GIS field with values 'Y' or 'N' as boolean.&#xD;&#xA;' Setting this field to true or false results in the ISCURRENT attribute being set to 'Y' or 'N'.&#xD;&#xA;&#xD;&#xA;' this is the value being set:&#xD;&#xA;dim bIsCurrent as Boolean = oContext.SetterValue &#xD;&#xA;&#xD;&#xA;' interpret value&#xD;&#xA;dim sIsCurrent as string&#xD;&#xA;if bIsCurrent then sIsCurrent=&quot;Y&quot; else sIsCurrent=&quot;N&quot;&#xD;&#xA;&#xD;&#xA;' access the gis attributes&#xD;&#xA;dim gisAttributes = oContext.GisFeature.Attributes&#xD;&#xA;&#xD;&#xA;' set the attributes &#xD;&#xA;gisAttributes.Item(&quot;ISCURRENT&quot;) = sIsCurrent&#xD;&#xA;"/>
			<record name="1100"
			        SNIPPETKEY="1100"
			        NAME="QueryByProximity"
			        DESCRIPTION="Snippet to query synced records by geographical Proximity"
			        CATEGORY="1033"
			        CODE="'' Example of querying records by geographical proximity.&#xD;&#xA;'' This example gets all addresses within 1000 feet of a given asset.&#xD;&#xA;&#xD;&#xA;'' The record to search from.  Your code should set this.&#xD;&#xA;Dim myAsset As IStormNode&#xD;&#xA;&#xD;&#xA;' Get geometry of the asset to search from&#xD;&#xA;Dim assetGeometry As Hansen.Core.Geom.Geometry = Hansen.Core.Extensions.ComponentGeometryExtensions.GetGeometry(myAsset)&#xD;&#xA;&#xD;&#xA;' Get nearby addresses&#xD;&#xA;Dim nearbyCollection As Hansen.GIS.ISyncIntegrationCollection = ServerApplication.NewComponent(Of Hansen.GIS.ISyncIntegrationCollection)()&#xD;&#xA;Dim wheres As DBOperativeCollection = New DBOperativeCollection()&#xD;&#xA;wheres.Add(New IDOperativeByCommonID(&quot;GIS&quot;, &quot;SyncIntegration.IpsMoniker&quot;, &quot;Hansen.Property.Address&quot;))&#xD;&#xA;&#xD;&#xA;'' Search integrated geometries within 1000 feet&#xD;&#xA;Dim distance = New Hansen.Core.Geom.Distance(1000, Hansen.Core.Configuration.LinearUnit.Feet)&#xD;&#xA;wheres.Add(New IDOperativeByCommonID(&quot;GIS&quot;, &quot;SyncIntegration.Geometry&quot;, New GeometryNearbyComparisonOperator(distance), assetGeometry))&#xD;&#xA;nearbyCollection.Load(wheres).Assert()&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;' Iterate the integration records found&#xD;&#xA;For Each nearby As Hansen.GIS.ISyncIntegration In nearbyCollection&#xD;&#xA;	Dim nearbyKey = nearby.IpsKey&#xD;&#xA;	Dim nearbyAddress As IUSAddress = ServerApplication.NewComponent(Of IUSAddress)()&#xD;&#xA;	nearbyAddress.AddressKey = nearbyKey&#xD;&#xA;	nearbyAddress.Load.Assert()&#xD;&#xA;&#xD;&#xA;	'' Do something with the address&#xD;&#xA;&#xD;&#xA;Next&#xD;&#xA;"/>
			<record name="1101"
			        SNIPPETKEY="1101"
			        NAME="ClearInactiveSync"
			        DESCRIPTION="Delete All sync Artifacts for inactive GIS Mappings"
			        CATEGORY="1033"
			        CODE="' Deletes all sync artifacts for inactive mappings&#xD;&#xA;&#xD;&#xA;dim mappings as Hansen.Gis.ISyncMappingCollection = ServerApplication.NewComponent(of Hansen.Gis.ISyncMappingCollection)()&#xD;&#xA;dim operatives = new DBOperativeCollection()&#xD;&#xA;operatives.Add(new IdOperativeByCommonId(&quot;Gis&quot;, &quot;SyncMapping.IsActive&quot;, &quot;N&quot;))&#xD;&#xA;dim res = mappings.Load(operatives, false)&#xD;&#xA;res.Assert()&#xD;&#xA;For Each mapping as Hansen.Gis.ISyncMapping in mappings&#xD;&#xA;	mapping.DeleteArtifacts()&#xD;&#xA;Next"/>
			<record name="1102"
			        SNIPPETKEY="1102"
			        NAME="GisGetZip5"
			        DESCRIPTION="Formula Field to Get Zip5 from Zip9"
			        CATEGORY="1037"
			        CODE="' example of a computed field for GIS Sync&#xD;&#xA;' this method represents a five-digit postal code when the source has a nine-digit postal code.&#xD;&#xA;&#xD;&#xA;' access the gis attributes&#xD;&#xA;dim gisAttributes = oContext.GisFeature.Attributes&#xD;&#xA;&#xD;&#xA;' get the attributes we need to compute the formula&#xD;&#xA;dim zip9 = gisAttributes.Item(&quot;ZIP&quot;).ToString()&#xD;&#xA;&#xD;&#xA;' extract a five-digit postal code&#xD;&#xA;dim zip5 as string&#xD;&#xA;if zip9.Length&gt;5 then &#xD;&#xA;     zip5 = zip9.Substring(0, 5)&#xD;&#xA;else &#xD;&#xA;     zip5 = zip9&#xD;&#xA;end if&#xD;&#xA;&#xD;&#xA;' return the result.  This will be the value of the computed field.&#xD;&#xA;retval = zip5&#xD;&#xA;"/>
			<record name="1103"
			        SNIPPETKEY="1103"
			        NAME="GisSetZip5"
			        DESCRIPTION="Formula Field to Set Zip5 to Zip9"
			        CATEGORY="1038"
			        CODE="' example of a computed field for GIS Sync&#xD;&#xA;' this method sets a nine-digit postal code when only five digits are provided.&#xD;&#xA;&#xD;&#xA;' this is the value being set:&#xD;&#xA;dim zip5 = oContext.SetterValue.ToString()&#xD;&#xA;&#xD;&#xA;' Append additional digits&#xD;&#xA;dim zip9 = zip5 + &quot;0000&quot;&#xD;&#xA;&#xD;&#xA;' access the gis attributes&#xD;&#xA;dim gisAttributes = oContext.GisFeature.Attributes&#xD;&#xA;&#xD;&#xA;' set the attributes &#xD;&#xA;gisAttributes.Item(&quot;ZIP&quot;) = zip9&#xD;&#xA;"/>
			<record name="1104"
			        SNIPPETKEY="1104"
			        NAME="BeforeSyncExample"
			        DESCRIPTION="Example Before Sync Validation"
			        CATEGORY="1036"
			        CODE="' Example of a pre-sync formula for GIS sync&#xD;&#xA;' this formula is to be run after obtaining data from both internal and external sources.&#xD;&#xA;' It allows modifications to be made to the data before syncing.&#xD;&#xA;&#xD;&#xA;' Get the records to be synced&#xD;&#xA;dim gisFeature = oBeforeSyncContext.GisFeature&#xD;&#xA;dim address as IAddress = oBeforeSyncContext.IpsComponent&#xD;&#xA;&#xD;&#xA;' Make Changes to the records&#xD;&#xA;if address.LegalOwner = nothing then &#xD;&#xA;     address.LegalOwner=&quot;Owner Not Recorded&quot;&#xD;&#xA;end if&#xD;&#xA;&#xD;&#xA;' Custom validation&#xD;&#xA;if gisFeature.Attributes.Item(&quot;OWNER&quot;) = nothing then&#xD;&#xA;     throw new Exception(&quot;No Owner recorded in GIS source&quot;)&#xD;&#xA;end if&#xD;&#xA;"/>
			<record name="1105"
			        SNIPPETKEY="1105"
			        NAME="AfterSyncExample"
			        DESCRIPTION="Example After Sync Validation"
			        CATEGORY="1035"
			        CODE="' Example of a post-sync formula for GIS sync&#xD;&#xA;&#xD;&#xA;' Get the record key from the sync audit&#xD;&#xA;dim ipsRecordKey = oSyncContext.SyncAudit.InternalRecordKey&#xD;&#xA;&#xD;&#xA;' Load the record from that key&#xD;&#xA;dim address as IAddress = ServerApplication.NewComponent(Of IAddress)()&#xD;&#xA;address.AddressKey = ipsRecordKey&#xD;&#xA;dim result = address.Load()&#xD;&#xA;&#xD;&#xA;if result.HasFailed then &#xD;&#xA;     ' If there is an error log the failure, and give a message.&#xD;&#xA;     oSyncContext.FailAdvancedSync(result.Message)&#xD;&#xA;else&#xD;&#xA;     ' Make post-sync updates to the component here&#xD;&#xA;     &#xD;&#xA;     &#xD;&#xA;     &#xD;&#xA;     'Optional: Add a sync activity to the sync audit&#xD;&#xA;     oSyncContext.AddActivity(&quot;Completed advanced activity&quot;)&#xD;&#xA;     'Optional: Generate a success message to appear in the sync audit details&#xD;&#xA;     oSyncContext.SucceedAdvancedSync(&quot;Advanced Sync Completed&quot;)&#xD;&#xA;end if&#xD;&#xA;&#xD;&#xA;"/>
			<record name="1106"
			        SNIPPETKEY="1106"
			        NAME="AssetLinkNearbyAddress"
			        DESCRIPTION="After Sync link new Assets to nearby Addresses"
			        CATEGORY="1035"
			        CODE="' Get Record from sync audit&#xD;&#xA;            Dim syncAudit As Hansen.GIS.ISyncAudit = oSyncContext.SyncAudit&#xD;&#xA;            If syncAudit.SyncCondition = Hansen.GIS.GisSyncCondition.Orphan And syncAudit.OriginatingSystem = Hansen.GIS.GisSyncSource.Gis Then&#xD;&#xA;&#xD;&#xA;                ' Load the asset&#xD;&#xA;                Dim assetKey = syncAudit.Integration.IpsKey&#xD;&#xA;                Dim asset As IStormNode = ServerApplication.NewComponent(Of IStormNode)()&#xD;&#xA;                asset.AssetKey = System.Int32.Parse(assetKey)&#xD;&#xA;                asset.Load().Assert()&#xD;&#xA;                If asset.Address.AddressKey = 1 Then&#xD;&#xA;&#xD;&#xA;                    ' Get geometry&#xD;&#xA;                    Dim assetGeometry As Hansen.Core.Geom.Geometry = Hansen.Core.Extensions.ComponentGeometryExtensions.GetGeometry(asset)&#xD;&#xA;&#xD;&#xA;                    ' Get nearby addresses&#xD;&#xA;                    Dim nearbyCollection As Hansen.GIS.ISyncIntegrationCollection = ServerApplication.NewComponent(Of Hansen.GIS.ISyncIntegrationCollection)()&#xD;&#xA;                    Dim wheres As DBOperativeCollection = New DBOperativeCollection()&#xD;&#xA;                    Dim distance = New Hansen.Core.Geom.Distance(1000, Hansen.Core.Configuration.LinearUnit.Feet)&#xD;&#xA;                    wheres.Add(New IDOperativeByCommonID(&quot;GIS&quot;, &quot;SyncIntegration.Geometry&quot;, New GeometryNearbyComparisonOperator(distance), assetGeometry))&#xD;&#xA;                    wheres.Add(New IDOperativeByCommonID(&quot;GIS&quot;, &quot;SyncIntegration.IpsMoniker&quot;, &quot;Hansen.Property.Address&quot;))&#xD;&#xA;                    nearbyCollection.Load(wheres).Assert()&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;                    ' Iterate the nearby addresses&#xD;&#xA;                    For Each nearby As Hansen.GIS.ISyncIntegration In nearbyCollection&#xD;&#xA;                        Dim nearbyKey = nearby.IpsKey&#xD;&#xA;                        Dim nearbyAddress As IUSAddress = ServerApplication.NewComponent(Of IUSAddress)()&#xD;&#xA;                        nearbyAddress.AddressKey = nearbyKey&#xD;&#xA;                        nearbyAddress.Load.Assert()&#xD;&#xA;&#xD;&#xA;                        'Associate the asset with the address&#xD;&#xA;                        asset.Address = nearbyAddress&#xD;&#xA;                        asset.Update().Assert()&#xD;&#xA;                        Exit For&#xD;&#xA;                    Next&#xD;&#xA;                End If&#xD;&#xA;&#xD;&#xA;                Throw New Exception()&#xD;&#xA;&#xD;&#xA;            End If"/>
			<record name="1107"
			        SNIPPETKEY="1107"
			        NAME="FilterAddressExample"
			        DESCRIPTION="Example IPS record filter for Sync"
			        CATEGORY="1039"
			        CODE="'' This is an example of a record filter formula to filter IPS records for GIS Sync.&#xD;&#xA;&#xD;&#xA;oCondition = new DBOperativeCollection()&#xD;&#xA;'' Add the filter condition as an operative. &#xD;&#xA;'' This example limits the addresses to be synced to those in a specific city.&#xD;&#xA;oCondition.Add (new IDOperativeByCommonId(&quot;Property&quot;, &quot;Address.City&quot;, ComparisonOperator.Like, &quot;MyCity&quot;))"/>
			<record name="1110"
			        SNIPPETKEY="1110"
			        NAME="Send with attachment"
			        DESCRIPTION="Send notification of type &quot;TYPE_NAME&quot; with a specific message and an attachment. &quot;/Test/MyFile.txt&quot; is the file to be attached, &quot;IPS&quot; is the document provider name, and &quot;FileName.txt&quot; is the name of the file when attached. &quot;EmailTemplate&quot; is the template ID to be used and referenceObject is the object defined in the Signature field."
			        CATEGORY="1028"
			        CODE="'Send notification of type &quot;TYPE_NAME&quot; with a specific message and an attachment. &quot;/Test/MyFile.txt&quot; is the file to be attached, &quot;IPS&quot; is the document provider name, and &quot;FileName.txt&quot; is the name of the file when attached. &quot;EmailTemplate&quot; is the template ID to be used and referenceObject is the object defined in the Signature field.&#xD;&#xA;&#xD;&#xA;Dim docService As Hansen.Core.DocumentManagement.Services.IDocumentService = ServerApplication.Resolve(Of Hansen.Core.DocumentManagement.Services.IDocumentService)&#xD;&#xA;Dim docRequest As New Hansen.Core.DocumentManagement.Services.GetDocumentRequest()&#xD;&#xA;docRequest.Uri = &quot;/Test/MyFile.txt&quot;&#xD;&#xA;docRequest.ProviderName = &quot;IPS&quot;&#xD;&#xA;Dim stream As System.IO.Stream = docService.GetDocument(docRequest)&#xD;&#xA;Dim attachment As New System.Net.Mail.Attachment(stream, &quot;FileName.txt&quot;)&#xD;&#xA;&#xD;&#xA;Dim message As New Hansen.Resources.Notifications.NotificationMessage(&quot;EmailTemplate&quot;, &quot;This message will be passed to the notification template in the {message.Message} property&quot;, referenceObject, &quot;TYPE_NAME&quot;)&#xD;&#xA;message.Attachments.Add(attachment)&#xD;&#xA;&#xD;&#xA;Hansen.Resources.Notifications.NotificationService.Send(message)"/>
			<record name="1111"
			        SNIPPETKEY="1111"
			        NAME="Backdate Expenditures"
			        DESCRIPTION="Example AfterUpdate formula for Backdating Asset Valuation"
			        CATEGORY="1040"
			        CODE="'Example snippet formula of Backdating an Asset Valuation from Work Order&#xD;&#xA;'This will allow to include the Work Order that has been completed on the Accounting Period that has already been depreciated.&#xD;&#xA;' Needed Parameters:&#xD;&#xA;' Asset&#xD;&#xA;' BackdateTo ( CompletedDateTime ) This date is needed when it will Backdate&#xD;&#xA;' Type ( AssetValuationType ) It's either Capita or Expens&#xD;&#xA;' Comments&#xD;&#xA;&#xD;&#xA;Dim res as Result&#xD;&#xA;Dim errorMessages as String&#xD;&#xA; &#xD;&#xA;dim backdate as Hansen.AssetManagement.AssetValuation.IAssetValuationBackdate = ServerApplication.NewComponent(&quot;Hansen.AssetManagement.AssetValuation.AssetValuationBackdate&quot;, oWorkOrder.UserInfo)&#xD;&#xA;res = backdate.BackdateValuation(oWorkOrder.Asset, oWorkOrder.CompletedDateTime, oWorkOrder.AssetValuationType, Nothing)&#xD;&#xA; &#xD;&#xA;For Each r as Result In res&#xD;&#xA;    If Not Result.SuccessLevels.Has(r.Severity) Then&#xD;&#xA;        'Handle all errors then display&#xD;&#xA;        errorMessages += r.Description&#xD;&#xA;        If r.Code = Hansen.AssetManagement.AssetValuation.AssetValuationBackdateErrors.NotWithinAccountingPeriod Then&#xD;&#xA;            'Do Something&#xD;&#xA;        ElseIf r.Code = Hansen.AssetManagement.AssetValuation.AssetValuationBackdateErrors.InvalidBackdateType Then&#xD;&#xA;            'Do Something&#xD;&#xA;        End If&#xD;&#xA;    End If&#xD;&#xA;Next&#xD;&#xA; &#xD;&#xA;If Not String.IsNullOrEmpty(errorMessages) Then&#xD;&#xA;    res = New Result(ResultCodes.InvalidValue, ResultSeverity.UserError, errorMessages)&#xD;&#xA;Else&#xD;&#xA;     res = Result.Success&#xD;&#xA;End if&#xD;&#xA; &#xD;&#xA;return res"/>
			<record name="1112"
			        SNIPPETKEY="1112"
			        NAME="Backdate Revaluation"
			        DESCRIPTION="Formula to mark an Asset Valuation as needing backdated depreciations calculated for Asset Revaluation backdating"
			        CATEGORY="1012"
			        CODE="'Sample formula to backdate an Asset Revaluation&#xD;&#xA;'Can be used in the Add or Update Workflows&#xD;&#xA;'If on the Update workflow, check that the Revaluation is not already journaled before running the backdate code is recommended.&#xD;&#xA;'if oRevaluation.JournalDate = NullDefault.DateTimeDefault&#xD;&#xA;&#xD;&#xA;Dim res as Result&#xD;&#xA;Dim avBackdate as Hansen.AssetManagement.AssetValuation.IAssetValuationBackdate = ServerApplication.NewComponent( &quot;Hansen.AssetManagement.AssetValuation.AssetValuationBackdate&quot;, oRevaluation.UserInfo )&#xD;&#xA;&#xD;&#xA;'Only create backdate requests for Revaluations which have not been journaled&#xD;&#xA;if oRevaluation.JournalDate = NullDefault.DateTimeDefault then&#xD;&#xA;	res = avBackdate.BackdateValuation( oRevaluation, oRevaluation.ValuatedDateTime, &quot;Comments&quot; )&#xD;&#xA;&#xD;&#xA;	if res.Code = Hansen.AssetManagement.AssetValuation.AssetValuationBackdateErrors.NotWithinAccountingPeriod then&#xD;&#xA;		'Unable to backdate due to the date being beyond what is allowed by the valuation book&#xD;&#xA;	end if	&#xD;&#xA;end if&#xD;&#xA;&#xD;&#xA;return res"/>
			<record name="1113"
			        SNIPPETKEY="1113"
			        NAME="Show Another Report"
			        DESCRIPTION="Calls a report defined under General Reports from a Formula Report and returns the output."
			        CATEGORY="1043"
