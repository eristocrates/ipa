			        CATEGORY="1032"
			        CODE="'Create a file and write some text to it&#xD;&#xA;Dim fileService As New FileExplorerService&#xD;&#xA;Dim filePath As String = &quot;Log\\ExampleDirectory\\File.txt&quot;&#xD;&#xA;If fileService.IsFileWritable(filePath) Then&#xD;&#xA;	fileService.WriteAllText(filePath, &quot;Hello World!&quot;)&#xD;&#xA;End If"/>
			<record name="1089"
