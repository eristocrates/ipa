			        METHODPREFIX="CM"
			        METHODSIGNATURE="out System.Boolean MilestoneCheck, Hansen.CDR.Project.IProjectApplication oProjApp"
			        DEFAULTDLLNAME="CDRPlanning"
			        DEFAULTCOMMENT="This CheckMilestonePROJ Event is for determining if a particular milestone has been met within a PlanningCondition.&lt;br&gt;&lt;br&gt;Available to be used within the calculation is a ProjectApplication object expressed as '&lt;b&gt;oProjApp&lt;/b&gt;'. The result should be a boolean variable returned through the variable named '&lt;b&gt;MilestoneCheck&lt;/b&gt;'.&lt;br&gt;&lt;br&gt;&lt;i&gt;Example:&lt;/i&gt;&lt;br&gt;&lt;span style='font-size:10.0pt;font-family:&quot;Courier New&quot;'&gt;&lt;span style='color:blue'&gt;If&lt;/span&gt;(oProjApp.NumberOfProjects&gt;5) &lt;span style='color:blue'&gt;Then&lt;/span&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;MilestoneCheck = &lt;span style='color:blue'&gt;True&lt;/span&gt;&lt;br&gt;&lt;span style='color:blue'&gt;Else&lt;/span&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;MilestoneCheck = &lt;span style='color:blue'&gt;False&lt;/span&gt;&lt;br&gt;&lt;span style='color:blue'&gt;End If&lt;/span&gt;"/>
			<record name="CDR.BuildingXPlanningConditionXAutoStatusChangeBLDG"
			        EVENTKEY="1688"
			        PRODFAMILYNAME="CDR.Building"
			        BUSOBJNAME="PlanningCondition"
			        PAGENAME=""
			        NAME="AutoStatusChangeBLDG"
			        NAMESPACE="CDR.Building"
			        METHODPREFIX="AS"
			        METHODSIGNATURE="out System.String StatusCode, Hansen.CDR.Building.IBuildingApplication oBldgApp"
			        DEFAULTDLLNAME="CDRPlanning"
			        DEFAULTCOMMENT="This AutoStatusChangeBLDG Event is for determining the new status of a planning condition after a milestone has been reached within a Building Application.&lt;br&gt;&lt;br&gt;Available to be used within the calculation is a BuildingApplication object expressed as '&lt;b&gt;oBldgApp&lt;/b&gt;'. The new desired status should be return as a string through the variable names '&lt;b&gt;StatusCode&lt;/b&gt;'. &lt;b&gt;StatusCode&lt;/b&gt; should be a valid code for one of the predefined Planning Condition Statuses.&lt;br&gt;&lt;br&gt;&lt;i&gt;Example:&amp;nbsp;&amp;nbsp;(Assumes the Planning Condition Statuses '&lt;b&gt;In Effect&lt;/b&gt;' and '&lt;b&gt;Met&lt;/b&gt;' are defined.)&lt;/i&gt;&lt;br&gt;&lt;span style='font-size:10.0pt;font-family:&quot;Courier New&quot;'&gt;&lt;span style='color:blue'&gt;If&lt;/span&gt;(oBldgApp.CheckFeeStatus()==0)&lt;span style='color:blue'&gt;Then&lt;/span&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;StatusCode = &quot;&lt;span style='color:purple'&gt;Met&lt;/span&gt;&quot;&lt;br&gt;&lt;span style='color:blue'&gt;Else&lt;/span&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;StatusCode = &quot;&lt;span style='color:purple'&gt;In Effect&lt;/span&gt;&quot;&lt;br&gt;&lt;span style='color:blue'&gt;End If&lt;/span&gt;&lt;/span&gt;"/>
			<record name="CDR.PlanningXPlanningConditionXAutoStatusChangePLAN"
			        EVENTKEY="1690"
			        PRODFAMILYNAME="CDR.Planning"
			        BUSOBJNAME="PlanningCondition"
			        PAGENAME=""
			        NAME="AutoStatusChangePLAN"
			        NAMESPACE="CDR.Planning"
			        METHODPREFIX="AS"
			        METHODSIGNATURE="out System.String StatusCode, Hansen.CDR.Planning.IPlanningApplication oPlanApp"
			        DEFAULTDLLNAME="CDRPlanning"
			        DEFAULTCOMMENT="This AutoStatusChangePLAN Event is for determining the new status of a planning condition after a milestone has been reached within a Planning Application.&lt;br&gt;&lt;br&gt;Available to be used within the calculation is a PlanningApplication object expressed as '&lt;b&gt;oPlanApp&lt;/b&gt;'. The new desired status should be return as a string through the variable names '&lt;b&gt;StatusCode&lt;/b&gt;'. &lt;b&gt;StatusCode&lt;/b&gt; should be a valid code for one of the predefined Planning Condition Statuses.&lt;br&gt;&lt;br&gt;&lt;i&gt;Example:&amp;nbsp;&amp;nbsp;(Assumes the Planning Condition Statuses '&lt;b&gt;In Effect&lt;/b&gt;' and '&lt;b&gt;Met&lt;/b&gt;' are defined.)&lt;/i&gt;&lt;br&gt;&lt;span style='font-size:10.0pt;font-family:&quot;Courier New&quot;'&gt;&lt;span style='color:blue'&gt;If&lt;/span&gt;(oPlanApp.CheckFeeStatus()==0)&lt;span style='color:blue'&gt;Then&lt;/span&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;StatusCode = &quot;&lt;span style='color:purple'&gt;Met&lt;/span&gt;&quot;&lt;br&gt;&lt;span style='color:blue'&gt;Else&lt;/span&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;StatusCode = &quot;&lt;span style='color:purple'&gt;In Effect&lt;/span&gt;&quot;&lt;br&gt;&lt;span style='color:blue'&gt;End If&lt;/span&gt;&lt;/span&gt;"/>
			<record name="AssetManagementXAssetInspectionIndexXWCIndexCalc"
			        EVENTKEY="2223"
			        PRODFAMILYNAME="AssetManagement"
			        BUSOBJNAME="AssetInspectionIndex"
			        PAGENAME=""
			        NAME="WCIndexCalc"
			        NAMESPACE="AssetManagement"
			        METHODPREFIX="WCCI"
			        METHODSIGNATURE="out System.Double IndexRating, System.String InspType, System.Int32 InspKey, Hansen.AssetManagement.SolidWaste.IWasteContainer oAsset"
			        DEFAULTDLLNAME="AssetManagement"
			        DEFAULTCOMMENT="&lt;P&gt;This formula is used&amp;nbsp; to calculate an index for an asset inspection.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&lt;STRONG&gt;The following parameters are available to use&lt;/STRONG&gt;:&lt;BR&gt;&lt;FONT color=#ff0000&gt;InspKey&lt;/FONT&gt; - The inspection key of the inspection for which the index is calculated.&lt;BR&gt;&lt;FONT color=#ff0000&gt;oAsset&lt;/FONT&gt; - The water hydrant business object.&amp;nbsp; A list of inspections for this asset can be found at oAsset.ServiceInspections&lt;BR&gt;&lt;FONT color=#ff0000&gt;IndexRating&lt;/FONT&gt; - The calculated index should be assigned to this System.Double parameter.&lt;/P&gt;&#xA;&#xD;&lt;P&gt;&lt;STRONG&gt;Below is a sample formula that will find the current inspection and set the IndexRating value to the value of&amp;nbsp;the &quot;Flow&quot;&lt;/STRONG&gt;&amp;nbsp;&lt;STRONG&gt;property on the &quot;AgencyID.Inspections.Flow&quot; agency business object.&lt;/STRONG&gt;&lt;/P&gt;&#xA;&#xD;&lt;P&gt;Dim res As Hansen.Core.Result&lt;BR&gt;Dim oInsp As Hansen.AssetManagement.SolidWaste.IWCServiceInspection&lt;/P&gt;&#xA;&#xD;&lt;P&gt;For Each oInsp In oAsset.ServiceInspections&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; If InspKey = oInsp.PrimaryKey Then&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; Dim oFlow as AgencyID.Inspections.Flow&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; oFlow = AgencyID.Inspections.Flow.GetInstanceFromParent&amp;nbsp;(oInsp,res)&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; IndexRating = oFlow.Flow&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; Exit For&lt;BR&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; End If&lt;BR&gt;Next&lt;/P&gt;"/>
